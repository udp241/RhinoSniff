<UserControl x:Class="RhinoSniff.Views.NmapScanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <TextBlock Text="Nmap Scanner"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,14,14,20">
            <StackPanel>

                <!-- Config card -->
                <Border Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="Radar" Width="18" Height="18"
                                                     Foreground="{DynamicResource AccentTeal}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Port scan configuration"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Target + Protocol -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TargetBox" Grid.Column="0" Height="34"
                                     VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     materialDesign:HintAssist.Hint="Target IPv4 or hostname"
                                     materialDesign:HintAssist.Foreground="{DynamicResource TextFaint}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                <ToggleButton x:Name="TcpToggle" IsChecked="True" Click="Proto_Click"
                                              Margin="0,0,4,0" Style="{StaticResource RhinoPillToggle}"
                                              Content="TCP" />
                                <ToggleButton x:Name="UdpToggle" Click="Proto_Click"
                                              Style="{StaticResource RhinoPillToggle}"
                                              Content="UDP" />
                            </StackPanel>
                        </Grid>

                        <!-- Port range -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="START PORT" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                <TextBox x:Name="PortStartBox" Text="1" Height="32"
                                         VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="END PORT" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                <TextBox x:Name="PortEndBox" Text="1024" Height="32"
                                         VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            </StackPanel>
                        </Grid>

                        <!-- Threads + Timeout steppers -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="THREADS (1-500)" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="30" Height="32" Click="ThreadsDec_Click"
                                            Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextSecondary}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Padding="0">
                                        <materialDesign:PackIcon Kind="Minus" Width="14" Height="14" />
                                    </Button>
                                    <TextBox Grid.Column="1" x:Name="ThreadsBox" Text="64" Height="32" Margin="4,0"
                                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                             FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                    <Button Grid.Column="2" Width="30" Height="32" Click="ThreadsInc_Click"
                                            Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextSecondary}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Padding="0">
                                        <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                <TextBlock Text="TIMEOUT (ms)" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Width="30" Height="32" Click="TimeoutDec_Click"
                                            Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextSecondary}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Padding="0">
                                        <materialDesign:PackIcon Kind="Minus" Width="14" Height="14" />
                                    </Button>
                                    <TextBox Grid.Column="1" x:Name="TimeoutBox" Text="500" Height="32" Margin="4,0"
                                             VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                             FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                    <Button Grid.Column="2" Width="30" Height="32" Click="TimeoutInc_Click"
                                            Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextSecondary}"
                                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" Padding="0">
                                        <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="UdpHint" Margin="0,0,0,10" FontSize="10"
                                   Foreground="{DynamicResource TextFaint}" TextWrapping="Wrap"
                                   Visibility="Collapsed"
                                   Text="UDP shows only ports that actually responded. Silent services won't appear (open|filtered is dropped to avoid false positives)." />

                        <!-- Run / Stop: stacked full-width, only one visible at a time -->
                        <Button x:Name="RunBtn" Click="Run_Click"
                                Height="40" Cursor="Hand" HorizontalAlignment="Stretch"
                                Background="{DynamicResource AccentTealDark}"
                                Foreground="{DynamicResource TextOnAccent}"
                                BorderBrush="{DynamicResource AccentTealDark}" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon x:Name="RunIcon" Kind="Play" Width="16" Height="16" VerticalAlignment="Center" />
                                <TextBlock x:Name="RunText" Text="Start Scan" FontSize="12" FontWeight="SemiBold"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CancelBtn" Click="Cancel_Click"
                                Height="40" Cursor="Hand" HorizontalAlignment="Stretch"
                                Visibility="Collapsed"
                                Background="Transparent"
                                Foreground="{DynamicResource StatusDanger}"
                                BorderBrush="{DynamicResource StatusDanger}" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Stop" Width="16" Height="16" VerticalAlignment="Center" />
                                <TextBlock Text="Stop Scan" FontSize="12" FontWeight="SemiBold"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Finish state text right-aligned below button -->
                        <TextBlock x:Name="ScanStateText" Text=""
                                   Margin="0,6,0,0" FontSize="10" FontFamily="Consolas"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Right" />

                        <ProgressBar x:Name="ScanProgress" Height="4" Minimum="0" Maximum="100"
                                     Value="0" Margin="0,4,0,0"
                                     Foreground="{DynamicResource AccentTealDark}"
                                     Background="{DynamicResource InputBg}" />

                        <TextBlock x:Name="StatusLine" Margin="0,8,0,0" FontSize="10"
                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Summary cards -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Margin="0,0,6,0"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="PROTOCOL" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBlock x:Name="CardProtocol" Text="TCP" FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimary}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Margin="6,0,6,0"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="PROGRESS" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBlock x:Name="CardProgress" Text="0/0" FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimary}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Margin="6,0,6,0"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="DURATION" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBlock x:Name="CardDuration" Text="N/A" FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimary}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Margin="6,0,0,0"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            CornerRadius="6" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="OPEN PORTS" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBlock x:Name="CardOpenCount" Text="0" FontSize="13" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextPrimary}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Results -->
                <Border Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="0">
                    <StackPanel>
                        <TextBlock Text="Open Ports" Margin="16,12,16,8"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <Border x:Name="ResultsEmpty" Padding="24" Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="PlayCircleOutline" Width="32" Height="32"
                                                         Foreground="{DynamicResource TextFaint}"
                                                         HorizontalAlignment="Center" />
                                <TextBlock Text="Run a scan to see open ports"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"
                                           FontSize="11" Foreground="{DynamicResource TextFaint}" />
                            </StackPanel>
                        </Border>
                        <!-- Column header -->
                        <Grid x:Name="ResultsHeader" Margin="16,0,16,4" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PORT" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" />
                            <TextBlock Grid.Column="1" Text="SERVICE" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" />
                            <TextBlock Grid.Column="2" Text="PROTOCOL" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" />
                            <TextBlock Grid.Column="3" Text="RTT" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" />
                        </Grid>
                        <ItemsControl x:Name="ResultsList" Padding="8,0,8,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource InputBg}"
                                            BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1"
                                            Padding="10,6" Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Port}"
                                                       FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Service}"
                                                       FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Proto}"
                                                       FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="{Binding ElapsedText}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource TextFaint}" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
