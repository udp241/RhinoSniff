<UserControl x:Class="RhinoSniff.Views.HotkeysSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Hotkeys"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource PillCapturingBg}"
                        CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="BoundPillText" Text="0 BOUND"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource PillCapturingText}" />
                </Border>
                <Button Grid.Column="3" Height="28" Padding="10,0"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        Click="ResetAll_Click" Cursor="Hand"
                        Background="{DynamicResource SidebarItemHover}"
                        Foreground="{DynamicResource StatusDanger}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        ToolTip="Clear every hotkey binding">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="RestoreAlert" Width="13" Height="13" VerticalAlignment="Center" />
                        <TextBlock Text="Reset All" Margin="4,0,0,0" FontSize="11" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,14,14,20">
            <StackPanel>
                <TextBlock Margin="0,0,0,8" FontSize="11"
                           Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                           Text="Global hotkeys work from any window. Focus a keybind box and press your combo. Press Backspace or Delete to clear. Combos require at least one modifier (Ctrl / Shift / Alt / Win)." />

                <!-- Categories render here -->
                <StackPanel x:Name="CategoriesHost" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
