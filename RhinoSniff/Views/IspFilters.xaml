<UserControl x:Class="RhinoSniff.Views.IspFilters"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ISP Filters"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource PillCapturingBg}"
                        CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="IspCountText" Text="0 RULES"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource PillCapturingText}" />
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,14,14,20">
            <StackPanel>
                <!-- Add card -->
                <Border Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="OfficeBuildingOutline" Width="18" Height="18"
                                                     Foreground="{DynamicResource AccentTeal}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="ISP Filter" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Margin="0,4,0,10" FontSize="11"
                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                   Text="Hide traffic from matching ISPs (substring, case-insensitive). Right-click any row in the grid and choose 'Hide ISP' to add it here. Leave empty to show all ISPs." />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IspInput" Grid.Column="0"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="Enter ISP name (e.g. Amazon, Cloudflare)"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     KeyDown="IspInput_KeyDown" />
                            <Button Grid.Column="1" Height="30" Margin="8,10,0,0" Padding="12,0"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Click="AddIsp_Click" Cursor="Hand"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Add" Margin="4,0,0,0" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Empty state -->
                        <Border x:Name="EmptyBanner" Visibility="Collapsed"
                                Background="{DynamicResource InputBg}"
                                BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                CornerRadius="6" Padding="18,16" Margin="0,6,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="OfficeBuildingOutline" Width="32" Height="32"
                                                         HorizontalAlignment="Center"
                                                         Foreground="{DynamicResource TextFaint}" />
                                <TextBlock Text="No ISP rules configured"
                                           HorizontalAlignment="Center" Margin="0,6,0,2"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock Text="All ISPs will be shown until you add a rule or right-click 'Hide ISP' on a row."
                                           HorizontalAlignment="Center" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}" />
                            </StackPanel>
                        </Border>

                        <!-- ISP rows -->
                        <ItemsControl x:Name="IspList" Margin="0,6,0,0" />

                        <!-- Behavior -->
                        <Border Margin="0,14,0,0" Background="{DynamicResource InputBg}"
                                BorderBrush="{DynamicResource InputBorder}" BorderThickness="1"
                                CornerRadius="6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="When a row's ISP matches a rule"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="Choose how matching rows appear in the grid."
                                               FontSize="10"
                                               Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>
                                <ComboBox x:Name="BehaviorCombo" Grid.Column="1"
                                          MinWidth="160" VerticalAlignment="Center"
                                          SelectionChanged="Behavior_Changed"
                                          Foreground="{DynamicResource TextPrimary}"
                                          materialDesign:HintAssist.Hint="Behavior"
                                          Style="{StaticResource MaterialDesignComboBox}">
                                    <ComboBoxItem Tag="Hide" Content="Hide (remove from grid)" />
                                    <ComboBoxItem Tag="Dim" Content="Dim (keep but fade)" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
