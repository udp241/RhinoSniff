<UserControl x:Class="RhinoSniff.Views.GeoIpLookup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Geo IP Lookup"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,14,14,20">
            <StackPanel>
                <!-- Input card -->
                <Border Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <materialDesign:PackIcon Kind="MapMarkerRadius" Width="18" Height="18"
                                                     Foreground="{DynamicResource AccentTeal}"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Look up any IPv4 address"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Margin="0,0,0,10" FontSize="11"
                                   Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                   Text="Uses ip-api.com to resolve geolocation, ISP, ASN, and hosting flags. Free tier, no key required." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IpBox" Grid.Column="0" Height="34"
                                     VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     materialDesign:HintAssist.Hint="e.g. 8.8.8.8"
                                     materialDesign:HintAssist.Foreground="{DynamicResource TextFaint}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     KeyDown="IpBox_KeyDown" />
                            <Button Grid.Column="1" x:Name="LookupBtn" Click="Lookup_Click"
                                    Height="34" Padding="16,0" Margin="8,0,0,0" Cursor="Hand"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    BorderBrush="{DynamicResource AccentTealDark}" BorderThickness="1"
                                    materialDesign:ButtonAssist.CornerRadius="17"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="LookupIcon" Kind="Magnify" Width="14" Height="14" VerticalAlignment="Center" />
                                    <TextBlock x:Name="LookupText" Text="Lookup" FontSize="11" FontWeight="SemiBold"
                                               Margin="6,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Result card -->
                <Border x:Name="ResultCard" Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="ResultIp" Text=""
                                       FontFamily="Consolas" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border x:Name="ProxyPill" Background="{DynamicResource PillLockedBg}"
                                        CornerRadius="10" Padding="8,2" Margin="6,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="PROXY" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource PillLockedText}" />
                                </Border>
                                <Border x:Name="HostingPill" Background="{DynamicResource PillLockedBg}"
                                        CornerRadius="10" Padding="8,2" Margin="6,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="HOSTING" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource PillLockedText}" />
                                </Border>
                                <Border x:Name="MobilePill" Background="{DynamicResource PillCapturingBg}"
                                        CornerRadius="10" Padding="8,2" Margin="6,0,0,0" Visibility="Collapsed">
                                    <TextBlock Text="MOBILE" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource PillCapturingText}" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="2" Rows="7" Margin="0,0,0,0">
                            <!-- row helpers: label + value repeated -->
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="COUNTRY" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="CountryText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="REGION" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="RegionText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="CITY" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="CityText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="ZIP" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="ZipText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="LATITUDE" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="LatText" Text="—" FontFamily="Consolas" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="LONGITUDE" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="LonText" Text="—" FontFamily="Consolas" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="TIMEZONE" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="TzText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="ISP" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="IspText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="ORGANIZATION" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="OrgText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="ASN" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="AsnText" Text="—" FontFamily="Consolas" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="HOSTNAME" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="HostText" Text="—" FontFamily="Consolas" FontSize="11"
                                           Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="CONTINENT" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="ContText" Text="—" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Error card -->
                <Border x:Name="ErrorCard" Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource StatusDanger}" BorderThickness="1"
                        CornerRadius="8" Padding="14,10"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Width="16" Height="16"
                                                 Foreground="{DynamicResource StatusDanger}"
                                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="ErrorText" Margin="8,0,0,0" FontSize="12"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
