<UserControl x:Class="RhinoSniff.Views.PingTool"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <TextBlock Text="Ping" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
        </Border>

        <Grid Grid.Row="1" Margin="14,14,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Config column -->
            <Border Grid.Column="0" Background="{DynamicResource CardBg}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,0,10,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <materialDesign:PackIcon Kind="AccessPointNetwork" Width="18" Height="18"
                                                 Foreground="{DynamicResource AccentTeal}"
                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Ping configuration"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Protocol segmented picker -->
                    <TextBlock Text="PROTOCOL" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <ToggleButton x:Name="IcmpToggle" IsChecked="True" Click="Proto_Click"
                                      Margin="0,0,4,0" Style="{StaticResource RhinoPillToggle}"
                                      Content="ICMP" />
                        <ToggleButton x:Name="TcpToggle" Click="Proto_Click"
                                      Margin="0,0,4,0" Style="{StaticResource RhinoPillToggle}"
                                      Content="TCP" />
                        <ToggleButton x:Name="UdpToggle" Click="Proto_Click"
                                      Style="{StaticResource RhinoPillToggle}"
                                      Content="UDP" />
                    </StackPanel>

                    <!-- Target + Port -->
                    <TextBlock Text="TARGET" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                    <TextBox x:Name="TargetBox" Height="32" Margin="0,0,0,10"
                             VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                             Foreground="{DynamicResource TextPrimary}"
                             materialDesign:HintAssist.Hint="e.g. 8.8.8.8 or google.com"
                             materialDesign:HintAssist.Foreground="{DynamicResource TextFaint}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                    <StackPanel x:Name="PortPanel" Visibility="Collapsed">
                        <TextBlock Text="PORT" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                        <TextBox x:Name="PortBox" Height="32" Margin="0,0,0,10"
                                 Text="80"
                                 VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    </StackPanel>

                    <!-- Count / Timeout / Interval -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock Text="COUNT" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBox x:Name="CountBox" Text="4" Height="32"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                            <TextBlock Text="TIMEOUT (ms)" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBox x:Name="TimeoutBox" Text="1000" Height="32"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock Text="INTERVAL (ms)" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBox x:Name="IntervalBox" Text="1000" Height="32"
                                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                        </StackPanel>
                    </Grid>

                    <!-- Payload size (ICMP only) -->
                    <StackPanel x:Name="PayloadPanel">
                        <TextBlock Text="PAYLOAD SIZE (bytes)" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                        <TextBox x:Name="PayloadBox" Text="32" Height="32" Margin="0,0,0,10"
                                 VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                 Foreground="{DynamicResource TextPrimary}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                    </StackPanel>

                    <TextBlock Margin="0,0,0,10" FontSize="10"
                               Foreground="{DynamicResource TextFaint}" TextWrapping="Wrap"
                               Text="ICMP may require Administrator privileges on some systems. TCP uses connect(), UDP sends an empty packet and checks for ICMP port-unreachable (best-effort)." />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="StatusLine" Text=""
                                   FontSize="10" Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Name="StopBtn" Click="Stop_Click"
                                Height="32" Padding="14,0" Margin="0,0,6,0" Cursor="Hand"
                                IsEnabled="False"
                                Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="16"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <TextBlock Text="Stop" FontSize="11" FontWeight="SemiBold" />
                        </Button>
                        <Button Grid.Column="2" x:Name="StartBtn" Click="Start_Click"
                                Height="32" Padding="18,0" Cursor="Hand"
                                Background="{DynamicResource AccentTealDark}"
                                Foreground="{DynamicResource TextOnAccent}"
                                BorderBrush="{DynamicResource AccentTealDark}" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="16"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon x:Name="StartIcon" Kind="Play" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock x:Name="StartText" Text="Start" FontSize="11" FontWeight="SemiBold"
                                           Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Log column -->
            <Border Grid.Column="1" Background="{DynamicResource CardBg}"
                    BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="0" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="16,12,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Log" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Name="ClearLogBtn" Click="ClearLog_Click"
                                Height="24" Padding="10,0" Cursor="Hand"
                                Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <TextBlock Text="Clear" FontSize="10" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" x:Name="LogScroller" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto" Padding="16,0,16,8">
                        <TextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                 Foreground="{DynamicResource TextPrimary}"
                                 TextWrapping="NoWrap" AcceptsReturn="True" />
                    </ScrollViewer>
                    <!-- Stats -->
                    <Border Grid.Row="2" Background="{DynamicResource InputBg}"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0"
                            Padding="16,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SENT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="SentStat" Text="0" FontFamily="Consolas" FontSize="14" Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="REPLIED" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="RepliedStat" Text="0" FontFamily="Consolas" FontSize="14" Foreground="{DynamicResource StatusSuccess}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="LOST" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="LostStat" Text="0" FontFamily="Consolas" FontSize="14" Foreground="{DynamicResource StatusDanger}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="AVG (ms)" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="AvgStat" Text="—" FontFamily="Consolas" FontSize="14" Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="LOSS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextFaint}" />
                                <TextBlock x:Name="LossStat" Text="0%" FontFamily="Consolas" FontSize="14" Foreground="{DynamicResource TextPrimary}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
