<UserControl x:Class="RhinoSniff.Views.SettingsGeneral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,14">
        <StackPanel>
            <TextBlock Text="General" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" />

            <!-- Enable notifications -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Enable notifications" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Show in-app toast notifications for events and alerts"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ToggleButton x:Name="NotificationsToggle" Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="NotificationsToggle_Click" />
                </Grid>
            </Border>

            <!-- Discord Rich Presence -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Enable Discord Rich Presence" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                            <Border x:Name="DiscordPill" Background="{DynamicResource PillCapturingBg}"
                                    CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="DiscordPillText" Text="ENABLED" FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource PillCapturingText}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Show RhinoSniff activity in your Discord status"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ToggleButton x:Name="DiscordToggle" Grid.Column="2" VerticalAlignment="Center"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="DiscordToggle_Click" />
                </Grid>
            </Border>

            <!-- Auto-save capture data -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Auto-save capture data" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Save capture state to disk on exit so it can be resumed next session"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ToggleButton x:Name="AutoSaveToggle" Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="AutoSaveToggle_Click" />
                </Grid>
            </Border>

            <!-- Auto remove inactive IPs -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Auto remove inactive IPs" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Remove rows from the grid when their traffic has gone silent"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ToggleButton x:Name="AutoRemoveInactiveToggle" Grid.Column="1" VerticalAlignment="Center"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="AutoRemoveInactiveToggle_Click" />
                </Grid>
            </Border>

            <!-- Resources card -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Resources" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="LearnButton" Height="32" Padding="12,0" Margin="0,0,8,0"
                                Click="LearnButton_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BookOpenVariant" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Learn about RhinoSniff" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DiscordButton" Height="32" Padding="12,0"
                                Click="DiscordButton_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Discord" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Join our Discord" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Getting Started Tutorial card -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Getting Started Tutorial" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Show the intro tutorial again on next launch"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="ResetTutorialButton" Height="32" Padding="12,0"
                            Click="ResetTutorialButton_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                        <TextBlock Text="Reset Tutorial" FontSize="11" />
                    </Button>
                </Grid>
            </Border>

            <!-- Advanced section -->
            <TextBlock Text="Advanced" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,8" />
            <TextBlock Text="Legacy toggles preserved from earlier versions."
                       FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10" />

            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
                <StackPanel>
                    <!-- Country flags -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Country flags" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="CountryFlagsToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="CountryFlagsToggle_Click" />
                    </Grid>
                    <!-- Geolocation -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Geolocation (ip-api lookups)" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="GeoToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="GeoToggle_Click" />
                    </Grid>
                    <!-- Hardware acceleration -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Hardware acceleration" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="HardwareAccelToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="HardwareAccelToggle_Click" />
                    </Grid>
                    <!-- Stay on top -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Stay on top of all windows" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="TopMostToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="TopMostToggle_Click" />
                    </Grid>
                    <!-- Sound alerts -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sound on new connection" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="SoundAlertsToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="SoundAlertsToggle_Click" />
                    </Grid>
                    <!-- Remember adapter -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Save your last used adapter" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="RememberAdapterToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="RememberAdapterToggle_Click" />
                    </Grid>
                    <!-- Auto-show side panel -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Automatically show control panel" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="AutoShowPanelToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="AutoShowPanelToggle_Click" />
                    </Grid>
                    <!-- Packet Analyser -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Packet Analyser (right-click row)" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="PacketAnalyserToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="PacketAnalyserToggle_Click" />
                    </Grid>
                    <!-- IP Labels -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="IP Labels (right-click → Create IP label)" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                        <ToggleButton x:Name="EnableLabelsToggle" Grid.Column="1" VerticalAlignment="Center"
                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                  Click="EnableLabelsToggle_Click" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Log file button -->
            <Button x:Name="OpenLogButton" Height="36" HorizontalAlignment="Left" Padding="14,0"
                    Click="OpenLogButton_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileDocumentOutline" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Open log file" FontSize="11" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
