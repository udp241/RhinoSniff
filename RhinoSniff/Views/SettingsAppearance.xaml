<UserControl x:Class="RhinoSniff.Views.SettingsAppearance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <UserControl.Resources>
        <!-- Swatch tile button: no background, outlined, turns accent-bordered when IsSelected (Tag trick). -->
        <Style x:Key="AccentSwatchStyle" TargetType="Button">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="72" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource InputBg}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SwatchBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwatchBorder" Property="BorderBrush" Value="{DynamicResource TextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,14">
        <StackPanel>
            <TextBlock Text="Appearance" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" />

            <!-- Theme card -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Theme" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock Text="Choose between Dark and Light mode"
                               FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ThemeDarkButton" Height="32" Width="96"
                                Click="ThemeDarkButton_Click" Cursor="Hand"
                                materialDesign:ButtonAssist.CornerRadius="4,0,0,4"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="WeatherNight" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Dark" FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ThemeLightButton" Height="32" Width="96"
                                Click="ThemeLightButton_Click" Cursor="Hand"
                                materialDesign:ButtonAssist.CornerRadius="0,4,4,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="WeatherSunny" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Light" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Accent color card — preset swatches -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="32" Height="32" CornerRadius="4"
                                Background="{DynamicResource AccentTealDark}" Margin="0,0,10,0">
                            <materialDesign:PackIcon Kind="PaletteOutline" Width="18" Height="18"
                                                     Foreground="{DynamicResource TextOnAccent}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Theme" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="Customize the accent color of the interface"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- 9 preset swatches (2 rows: 5 + 4). Tag=hex drives ApplyAccent. -->
                    <WrapPanel x:Name="AccentSwatchPanel" HorizontalAlignment="Left">
                        <Button x:Name="SwatchCyan"   Tag="#06B6D4" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FF06B6D4" />
                                    <materialDesign:PackIcon x:Name="SwatchCyanCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Cyan" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchBlue"   Tag="#3B82F6" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FF3B82F6" />
                                    <materialDesign:PackIcon x:Name="SwatchBlueCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Blue" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchPurple" Tag="#8B5CF6" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FF8B5CF6" />
                                    <materialDesign:PackIcon x:Name="SwatchPurpleCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Purple" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchPink"   Tag="#EC4899" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FFEC4899" />
                                    <materialDesign:PackIcon x:Name="SwatchPinkCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Pink" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchRed"    Tag="#EF4444" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FFEF4444" />
                                    <materialDesign:PackIcon x:Name="SwatchRedCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Red" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchOrange" Tag="#F97316" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FFF97316" />
                                    <materialDesign:PackIcon x:Name="SwatchOrangeCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Orange" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchYellow" Tag="#EAB308" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FFEAB308" />
                                    <materialDesign:PackIcon x:Name="SwatchYellowCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Yellow" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchGreen"  Tag="#22C55E" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FF22C55E" />
                                    <materialDesign:PackIcon x:Name="SwatchGreenCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Green" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SwatchTeal"   Tag="#00897B" Click="AccentSwatch_Click" Style="{StaticResource AccentSwatchStyle}">
                            <StackPanel>
                                <Grid Width="28" Height="28" HorizontalAlignment="Center">
                                    <Ellipse Fill="#FF00897B" />
                                    <materialDesign:PackIcon x:Name="SwatchTealCheck" Kind="Check" Width="16" Height="16"
                                                             Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Visibility="Collapsed" />
                                </Grid>
                                <TextBlock Text="Teal" FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>

                    <!-- Footer: saved-locally note + Reset to Default -->
                    <Border BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0"
                            Margin="0,14,0,0" Padding="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Theme preference is saved locally"
                                       FontSize="10" Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="AccentResetButton"
                                    Click="AccentResetButton_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="10,4">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restore" Width="14" Height="14" Margin="0,0,6,0" />
                                    <TextBlock Text="Reset to Default" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Font Family card (v2.9.2) -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Font" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock Text="Pick the font used across the app. Restart for full effect."
                               FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,10" />
                    <ComboBox x:Name="FontFamilyCombo" Width="220" HorizontalAlignment="Left"
                              Foreground="{DynamicResource TextPrimary}"
                              SelectionChanged="FontFamilyCombo_SelectionChanged">
                        <ComboBoxItem Content="Gotham" />
                        <ComboBoxItem Content="Segoe UI" />
                        <ComboBoxItem Content="Consolas" />
                        <ComboBoxItem Content="Cascadia Code" />
                        <ComboBoxItem Content="Verdana" />
                        <ComboBoxItem Content="Tahoma" />
                        <ComboBoxItem Content="Arial" />
                        <ComboBoxItem Content="Calibri" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Background card -->
            <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Background Image" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock x:Name="BackgroundLabel" Text="Selected: None"
                               FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="PickImageButton" Height="32" Padding="12,0" Margin="0,0,8,0"
                                Click="PickImageButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageOutline" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Pick image..." FontSize="11" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ClearBackgroundButton" Height="32" Padding="12,0"
                                Click="ClearBackgroundButton_Click"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="WindowClose" Width="14" Height="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" FontSize="11" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Reset Appearance -->
            <Button x:Name="ResetAppearanceButton" Height="36" HorizontalAlignment="Left" Padding="14,0"
                    Click="ResetAppearanceButton_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Restore" Width="14" Height="14" Margin="0,0,6,0" />
                    <TextBlock Text="Reset Appearance" FontSize="11" />
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
