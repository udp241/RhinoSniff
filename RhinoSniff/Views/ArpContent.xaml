<UserControl x:Class="RhinoSniff.Views.ArpContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="ARP Network Discovery"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource PillCapturingBg}"
                        CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="DeviceCountPill" Text="0 DEVICES"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource PillCapturingText}" />
                </Border>
                <Border Grid.Column="2" Background="{DynamicResource PillStoppedBg}"
                        CornerRadius="10" Padding="8,2" Margin="6,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="SelectedPill" Text="NONE SELECTED"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource PillStoppedText}" />
                </Border>

                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button x:Name="RefreshBtn" Click="Refresh_Click" Height="28"
                            Padding="12,0" Margin="0,0,6,0" Cursor="Hand"
                            Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            materialDesign:ButtonAssist.CornerRadius="14"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Refresh" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ClearBtn" Click="Clear_Click" Height="28"
                            Padding="12,0" Margin="0,0,6,0" Cursor="Hand"
                            Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            materialDesign:ButtonAssist.CornerRadius="14"
                            Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TrashCanOutline" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Clear" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ScanBtn" Click="Scan_Click" Height="28"
                            Padding="14,0" Cursor="Hand"
                            Background="{DynamicResource AccentTealDark}"
                            Foreground="{DynamicResource TextOnAccent}"
                            BorderBrush="{DynamicResource AccentTealDark}" BorderThickness="1"
                            materialDesign:ButtonAssist.CornerRadius="14"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon x:Name="ScanIcon" Kind="Wifi" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock x:Name="ScanText" Text="Scan Network" FontSize="11" FontWeight="SemiBold"
                                       Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Gateway + manual add strip -->
        <Border Grid.Row="1" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        CornerRadius="6" Padding="10,6" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="RouterWireless" Width="16" Height="16"
                                                 Foreground="{DynamicResource AccentTeal}"
                                                 VerticalAlignment="Center" />
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="GATEWAY" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" />
                            <TextBlock x:Name="GatewayText" Text="Detecting..."
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock x:Name="GatewayMacText" Text="--:--:--:--:--:--"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="{DynamicResource TextMuted}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBox x:Name="ManualIpBox" Grid.Column="2" Width="170" Height="30"
                         VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                         Foreground="{DynamicResource TextPrimary}"
                         materialDesign:HintAssist.Hint="Add device by IP (e.g. 192.168.1.50)"
                         materialDesign:HintAssist.Foreground="{DynamicResource TextFaint}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         KeyDown="ManualIp_KeyDown" />
                <Button Grid.Column="3" x:Name="ManualAddBtn" Click="ManualAdd_Click"
                        Height="30" Padding="12,0" Margin="6,0,0,0" Cursor="Hand"
                        Background="{DynamicResource CardBg}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        materialDesign:ButtonAssist.CornerRadius="15"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Add" FontSize="11" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Device list -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <Border x:Name="EmptyState" Background="Transparent"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="30" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="WifiOff" Width="48" Height="48"
                                             Foreground="{DynamicResource TextFaint}"
                                             HorizontalAlignment="Center" />
                    <TextBlock Text="No devices found"
                               HorizontalAlignment="Center" Margin="0,12,0,4"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}" />
                    <TextBlock Text="Run a network scan to discover devices on your LAN."
                               HorizontalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource TextFaint}" />
                </StackPanel>
            </Border>

            <DataGrid x:Name="DeviceGrid" Margin="14,10,14,10"
                      Visibility="Collapsed"
                      AutoGenerateColumns="False" Background="{x:Null}"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserReorderColumns="False" CanUserResizeRows="False"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      HeadersVisibility="Column" RowHeight="32" ColumnHeaderHeight="30"
                      BorderThickness="1" BorderBrush="{DynamicResource CardBorder}"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource Divider}"
                      VerticalGridLinesBrush="Transparent"
                      IsReadOnly="True" SelectionChanged="DeviceGrid_SelectionChanged">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                        <Setter Property="FontSize" Value="10" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
                        <Setter Property="Background" Value="{DynamicResource TabInactiveBg}" />
                        <Setter Property="Padding" Value="10,0" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Click="DeviceCheckBox_Click" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="IP ADDRESS" Binding="{Binding IpAddress}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter Property="Padding" Value="10,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="MAC ADDRESS" Binding="{Binding MacAddress}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Consolas" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                <Setter Property="Padding" Value="10,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFaint}" />
                                <Setter Property="Padding" Value="10,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CardBgHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SidebarItemSelectedBg}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Grid>

        <!-- Bottom action bar -->
        <Border Grid.Row="3" Background="{DynamicResource BottomStatusBg}"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <CheckBox x:Name="NullRouteBox" VerticalAlignment="Center"
                              Foreground="{DynamicResource TextSecondary}">
                        <StackPanel>
                            <TextBlock Text="Null-route" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <TextBlock Text="Kill target's internet entirely" FontSize="10"
                                       Foreground="{DynamicResource TextFaint}" />
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="StatusLine" Text=""
                           Margin="16,0" VerticalAlignment="Center"
                           FontSize="11" Foreground="{DynamicResource TextMuted}"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="2" x:Name="SaveBtn" Click="Save_Click"
                        Height="32" Padding="14,0" Margin="0,0,6,0" Cursor="Hand"
                        IsEnabled="False"
                        Background="{DynamicResource CardBg}"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                        materialDesign:ButtonAssist.CornerRadius="16"
                        Style="{StaticResource MaterialDesignOutlinedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock Text="Save Target" FontSize="11" FontWeight="SemiBold"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="3" x:Name="ToggleBtn" Click="Toggle_Click"
                        Height="32" Padding="14,0" Cursor="Hand"
                        IsEnabled="False"
                        Background="{DynamicResource AccentTealDark}"
                        Foreground="{DynamicResource TextOnAccent}"
                        BorderBrush="{DynamicResource AccentTealDark}" BorderThickness="1"
                        materialDesign:ButtonAssist.CornerRadius="16"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon x:Name="ToggleIcon" Kind="Play" Width="14" Height="14" VerticalAlignment="Center" />
                        <TextBlock x:Name="ToggleText" Text="Start ARP" FontSize="11" FontWeight="SemiBold"
                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
