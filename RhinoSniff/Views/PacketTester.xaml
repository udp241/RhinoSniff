<UserControl x:Class="RhinoSniff.Views.PacketTester"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <materialDesign:DialogHost x:Name="PageDialogHost" Identifier="PacketTesterDialog" CloseOnClickAway="False">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Packet Tester"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" />
                    <Border Grid.Column="1" Background="{DynamicResource PillLockedBg}"
                            CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="ADVANCED" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource PillLockedText}" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,14,14,20">
                <StackPanel>

                    <!-- Warning banner -->
                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource StatusWarning}" BorderThickness="1"
                            CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertOutline" Width="18" Height="18"
                                                     Foreground="{DynamicResource StatusWarning}"
                                                     VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap"
                                       MaxWidth="780" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Text="Sends arbitrary UDP/TCP packets to a target. Use only on networks and endpoints you own or have explicit permission to test. Sending unsolicited traffic to third-party services can violate laws and terms of service." />
                        </StackPanel>
                    </Border>

                    <!-- Config card -->
                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,0,0,14">
                        <StackPanel>
                            <!-- Target IP + Port + Source Port -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="TARGET IPv4" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <TextBox x:Name="IpBox" Height="32"
                                             VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             materialDesign:HintAssist.Hint="e.g. 192.168.1.50"
                                             materialDesign:HintAssist.Foreground="{DynamicResource TextFaint}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                    <TextBlock Text="PORT" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <TextBox x:Name="PortBox" Text="3074" Height="32"
                                             VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="SOURCE PORT (0=any)" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <TextBox x:Name="SrcPortBox" Text="0" Height="32"
                                             VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </StackPanel>
                            </Grid>

                            <!-- Protocol + Payload type -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="PROTOCOL" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton x:Name="UdpToggle" IsChecked="True" Click="Proto_Click"
                                                      Margin="0,0,4,0" Style="{StaticResource RhinoPillToggle}"
                                                      Content="UDP" />
                                        <ToggleButton x:Name="TcpToggle" Click="Proto_Click"
                                                      Style="{StaticResource RhinoPillToggle}"
                                                      Content="TCP" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="PAYLOAD TYPE" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <ToggleButton x:Name="HexToggle" IsChecked="True" Click="Payload_Click"
                                                      Margin="0,0,4,0" Style="{StaticResource RhinoPillToggle}"
                                                      Content="HEX" />
                                        <ToggleButton x:Name="AsciiToggle" Click="Payload_Click"
                                                      Style="{StaticResource RhinoPillToggle}"
                                                      Content="ASCII" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Payload textarea -->
                            <TextBlock Text="PAYLOAD" FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                            <TextBox x:Name="PayloadBox" MinHeight="90" AcceptsReturn="True"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     materialDesign:HintAssist.Hint="e.g. FF 00 A1 or 0xFF,0x00,0xA1"
                                     materialDesign:HintAssist.Foreground="{DynamicResource TextFaint}"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     Margin="0,0,0,10" />

                            <!-- Loop + count -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <CheckBox x:Name="LoopBox" VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextSecondary}" />
                                    <TextBlock Text="Loop" Margin="6,0,0,0" VerticalAlignment="Center"
                                               FontSize="12" Foreground="{DynamicResource TextPrimary}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                    <TextBlock Text="COUNT" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <TextBox x:Name="CountBox" Text="1" Height="28"
                                             VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                    <TextBlock Text="INTERVAL (ms)" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,0,0,4" />
                                    <TextBox x:Name="IntervalBox" Text="50" Height="28"
                                             VerticalContentAlignment="Center" FontFamily="Consolas" FontSize="12"
                                             Foreground="{DynamicResource TextPrimary}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </StackPanel>
                            </Grid>

                            <!-- Action row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" x:Name="StatusLine" Text=""
                                           VerticalAlignment="Center"
                                           FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="1" x:Name="StopBtn" Click="Stop_Click"
                                        Height="32" Padding="14,0" Margin="0,0,6,0" Cursor="Hand"
                                        IsEnabled="False"
                                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        materialDesign:ButtonAssist.CornerRadius="16"
                                        Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <TextBlock Text="Stop" FontSize="11" FontWeight="SemiBold" />
                                </Button>
                                <Button Grid.Column="2" x:Name="SendBtn" Click="Send_Click"
                                        Height="32" Padding="18,0" Cursor="Hand"
                                        Background="{DynamicResource AccentTealDark}"
                                        Foreground="{DynamicResource TextOnAccent}"
                                        BorderBrush="{DynamicResource AccentTealDark}" BorderThickness="1"
                                        materialDesign:ButtonAssist.CornerRadius="16"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="SendIcon" Kind="Send" Width="14" Height="14" VerticalAlignment="Center" />
                                        <TextBlock x:Name="SendText" Text="Send" FontSize="11" FontWeight="SemiBold"
                                                   Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Log -->
                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="16,12,16,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Send log" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" x:Name="ClearLogBtn" Click="ClearLog_Click"
                                        Height="24" Padding="10,0" Cursor="Hand"
                                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                                        BorderBrush="{DynamicResource CardBorder}" BorderThickness="1"
                                        materialDesign:ButtonAssist.CornerRadius="12"
                                        Style="{StaticResource MaterialDesignOutlinedButton}">
                                    <TextBlock Text="Clear" FontSize="10" />
                                </Button>
                            </Grid>
                            <ScrollViewer Grid.Row="1" x:Name="LogScroller" VerticalScrollBarVisibility="Auto" MaxHeight="220"
                                          Padding="16,0,16,12">
                                <TextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                                         Foreground="{DynamicResource TextPrimary}"
                                         TextWrapping="NoWrap" AcceptsReturn="True" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
