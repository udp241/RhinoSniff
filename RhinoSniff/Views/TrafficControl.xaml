<UserControl x:Class="RhinoSniff.Views.TrafficControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /><!-- header -->
            <RowDefinition Height="Auto" /><!-- stats bar -->
            <RowDefinition Height="*" />   <!-- rules list -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10"
                BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /><!-- title -->
                    <ColumnDefinition Width="Auto" /><!-- tooltip -->
                    <ColumnDefinition Width="Auto" /><!-- pill -->
                    <ColumnDefinition Width="*" />   <!-- spacer -->
                    <ColumnDefinition Width="Auto" /><!-- start/stop -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Traffic Control" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />

                <!-- Info tooltip -->
                <materialDesign:PackIcon Grid.Column="1" Kind="InformationOutline"
                    Width="14" Height="14" Margin="6,0,0,0" VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFaint}" Cursor="Help"
                    ToolTip="Manipulate network traffic with lag, drop, throttle, and more" />

                <!-- Status pill -->
                <Border Grid.Column="2" x:Name="StatePill" Background="{DynamicResource PillStoppedBg}"
                        CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StateDot" Width="6" Height="6" Margin="0,0,5,0"
                                 VerticalAlignment="Center" Fill="{DynamicResource StatusDanger}" />
                        <TextBlock x:Name="StateText" Text="STOPPED" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource PillStoppedText}" />
                    </StackPanel>
                </Border>

                <!-- Start / Stop button -->
                <Button Grid.Column="4" x:Name="StartStopButton" Height="30" Padding="12,0"
                        materialDesign:ButtonAssist.CornerRadius="4"
                        Click="StartStop_Click" Cursor="Hand"
                        Background="{DynamicResource AccentBlue}"
                        Foreground="{DynamicResource TextOnAccent}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon x:Name="StartStopIcon" Kind="Play" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock x:Name="StartStopText" Text="Start" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ STATS BAR ════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{DynamicResource CardBg}" Margin="14,10,14,0"
                CornerRadius="6" Padding="10,8">
            <UniformGrid Columns="6">
                <!-- Processed -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="PROCESSED" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="StatProcessed" Text="0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center"
                               FontFamily="Consolas" />
                </StackPanel>
                <!-- Dropped -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="DROPPED" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="StatDropped" Text="0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ActionDrop}" HorizontalAlignment="Center"
                               FontFamily="Consolas" />
                </StackPanel>
                <!-- Delayed -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="DELAYED" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="StatDelayed" Text="0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ActionLag}" HorizontalAlignment="Center"
                               FontFamily="Consolas" />
                </StackPanel>
                <!-- Reordered -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="REORDERED" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="StatReordered" Text="0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ActionReorder}" HorizontalAlignment="Center"
                               FontFamily="Consolas" />
                </StackPanel>
                <!-- Duplicated -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="DUPLICATED" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="StatDuplicated" Text="0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ActionDuplicate}" HorizontalAlignment="Center"
                               FontFamily="Consolas" />
                </StackPanel>
                <!-- Throttled -->
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="THROTTLED" FontSize="9" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="StatThrottled" Text="0" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ActionThrottle}" HorizontalAlignment="Center"
                               FontFamily="Consolas" />
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- ═══ RULES SECTION ════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="14,10,14,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><!-- rules header -->
                <RowDefinition Height="*" />   <!-- rules body -->
            </Grid.RowDefinitions>

            <!-- Rules header: "Rules (N)" + "+ Add Rule" -->
            <Border Grid.Row="0" Background="{DynamicResource CardBg}" CornerRadius="6,6,0,0"
                    Padding="12,8" BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="RulesHeaderText" Text="Rules (0)"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Height="26" Padding="10,0"
                            materialDesign:ButtonAssist.CornerRadius="4"
                            Click="AddRule_Click" Cursor="Hand"
                            Background="{DynamicResource AccentBlue}"
                            Foreground="{DynamicResource TextOnAccent}"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="13" Height="13"
                                                     VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="Add Rule" FontSize="11" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Rules body -->
            <Border Grid.Row="1" Background="{DynamicResource CardBg}" CornerRadius="0,0,6,6">
                <Grid>
                    <!-- Empty state (visible when no rules) -->
                    <StackPanel x:Name="EmptyState" Visibility="Visible"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,40,0,40">
                        <materialDesign:PackIcon Kind="TuneVariant" Width="40" Height="40"
                            HorizontalAlignment="Center" Foreground="{DynamicResource TextFaint}" />
                        <TextBlock Text="No rules configured" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,8,0,2"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Add a rule to start manipulating traffic" FontSize="11"
                                   Foreground="{DynamicResource TextFaint}" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Rule list (scrollable) -->
                    <ScrollViewer x:Name="RuleListScroll" VerticalScrollBarVisibility="Auto"
                                  Visibility="Collapsed" Padding="0,4,0,4">
                        <ItemsControl x:Name="RuleList" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ TOAST BAR (bottom, overlaid) ═════════════════════════════ -->
        <Border x:Name="ToastBar" Grid.Row="2" VerticalAlignment="Bottom"
                Margin="14,0,14,14" CornerRadius="6" Padding="12,8"
                Visibility="Collapsed"
                Background="{DynamicResource StatusDanger}"
                Opacity="0.95">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ToastText" Grid.Column="0" FontSize="11"
                           Foreground="White" VerticalAlignment="Center" />
                <Button Grid.Column="1" Width="18" Height="18" Padding="0"
                        Click="ToastDismiss_Click" Cursor="Hand"
                        Background="Transparent" BorderBrush="{x:Null}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <materialDesign:PackIcon Kind="Close" Width="12" Height="12" Foreground="White" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
