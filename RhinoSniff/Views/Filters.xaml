<Page x:Class="RhinoSniff.Views.Filters"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Title="Account"
      d:DesignHeight="541"
      d:DesignWidth="296"
      FontFamily="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham"
      mc:Ignorable="d">
    <Grid>
        <ScrollViewer MaxWidth="296"
                      HorizontalContentAlignment="Left"
                      VerticalContentAlignment="Top"
                      AutomationProperties.IsOffscreenBehavior="Default"
                      HorizontalScrollBarVisibility="Hidden">
            <Grid MaxWidth="296"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Margin="15,15,20,10"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="Game filters" />
                    <TextBlock Margin="20,0,20,6"
                               Foreground="#99FFFFFF" FontSize="11"
                               TextWrapping="Wrap"
                               Text="Select one or more filters." />
                    <Border Margin="10,0,10,10" BorderBrush="#1AFFFFFF" BorderThickness="1"
                            CornerRadius="4" MaxHeight="280">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="FilterCheckboxPanel">
                                <!-- Header row -->
                                <Grid Margin="0,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="62" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="1" Text="NAME" Foreground="#66FFFFFF" FontSize="9" Margin="4,0" />
                                    <TextBlock Grid.Column="2" Text="TYPE" Foreground="#66FFFFFF" FontSize="9" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="CONSOLE" Foreground="#66FFFFFF" FontSize="9" HorizontalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- ISP filter -->
                    <TextBlock Margin="15,5,20,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="ISP filter" />
                    <TextBlock Margin="20,0,20,4"
                               Foreground="#99FFFFFF" FontSize="11"
                               TextWrapping="Wrap"
                               Text="Only show connections from this ISP (leave blank for all)." />
                    <TextBox x:Name="IspFilterBox"
                             Margin="20,0,20,10"
                             Foreground="White" FontSize="12"
                             materialDesign:HintAssist.Hint="e.g. Comcast, Bell, Vianet"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             TextChanged="IspFilter_TextChanged" />

                    <!-- Console IP Filter -->
                    <TextBlock Margin="15,5,20,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="Console IP filter" />
                    <TextBlock Margin="20,0,20,4"
                               Foreground="#99FFFFFF" FontSize="11"
                               TextWrapping="Wrap"
                               Text="Enter your console/device IPv4 to hide it from results. Leave blank for PC sniffing." />
                    <TextBox x:Name="ConsoleIpFilterBox"
                             Margin="20,0,20,10"
                             Foreground="White" FontSize="12"
                             materialDesign:HintAssist.Hint="e.g. 192.168.1.50"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             TextChanged="ConsoleIpFilter_TextChanged" />

                    <!-- Interface options -->
                    <TextBlock Margin="15,10,20,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="Interface" />
                    <StackPanel Margin="20,4,20,10" Orientation="Horizontal">
                        <ToggleButton x:Name="OtherInfoToggle"
                                      Cursor="Arrow"
                                      Style="{DynamicResource MaterialDesignSwitchToggleButton}" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="White" FontSize="12"
                                   Text="Show 'All Traffic' tab" />
                    </StackPanel>
                    <StackPanel Margin="20,4,20,10" Orientation="Horizontal">
                        <ToggleButton x:Name="AutoRemoveInactiveToggle"
                                      Cursor="Arrow"
                                      Style="{DynamicResource MaterialDesignSwitchToggleButton}" />
                        <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="White" FontSize="12"
                                   Text="Auto Remove Inactive IPs From Results" />
                    </StackPanel>

                    <!-- Packet Types -->
                    <TextBlock Margin="15,10,20,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="Packet types" />
                    <StackPanel Margin="20,4,20,4" Orientation="Horizontal">
                        <CheckBox x:Name="ShowUdpToggle"
                                  IsChecked="True"
                                  Cursor="Arrow"
                                  Foreground="White" FontSize="12"
                                  Content="Show UDP Packets" />
                    </StackPanel>
                    <StackPanel Margin="20,4,20,10" Orientation="Horizontal">
                        <CheckBox x:Name="ShowTcpToggle"
                                  IsChecked="True"
                                  Cursor="Arrow"
                                  Foreground="White" FontSize="12"
                                  Content="Show TCP Packets" />
                    </StackPanel>

                    <!-- Custom Filters section -->
                    <TextBlock Margin="15,15,20,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="Custom filters" />
                    <TextBlock Margin="20,0,20,8"
                               Foreground="#99FFFFFF" FontSize="11"
                               TextWrapping="Wrap"
                               Text="Create your own filter by port range. Check 'Custom' in the game filters list to use." />

                    <StackPanel Margin="20,5,20,5">
                        <TextBox x:Name="CustomNameBox"
                                 Margin="0,0,0,5"
                                 Foreground="White" FontSize="12"
                                 materialDesign:HintAssist.Hint="Filter name (e.g. My Game)"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CustomMinPortBox"
                                     Grid.Column="0"
                                     Foreground="White" FontSize="12"
                                     materialDesign:HintAssist.Hint="Min port"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                            <TextBox x:Name="CustomMaxPortBox"
                                     Grid.Column="2"
                                     Foreground="White" FontSize="12"
                                     materialDesign:HintAssist.Hint="Max port"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                        </Grid>
                        <Button Margin="0,8,0,5"
                                Height="32" HorizontalAlignment="Stretch"
                                Click="AddCustomFilter_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Background="#1AFFFFFF" Foreground="White" Cursor="Arrow">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" />
                                <TextBlock Text="ADD FILTER" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ListBox x:Name="CustomFilterListBox"
                             Margin="20,0,20,10"
                             MaxHeight="120">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Click="DeleteCustomFilter_Click">
                                    <MenuItem.Icon>
                                        <materialDesign:PackIcon Kind="TrashOutline" />
                                    </MenuItem.Icon>
                                    <MenuItem.Header>
                                        <TextBlock>Delete filter</TextBlock>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>

                    <!-- Port blacklist section (existing) -->
                    <TextBlock Margin="15,5,20,10"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Style="{StaticResource RhinoSniffSubtitle}"
                               Text="Port blacklist" />
                    <Grid Margin="20,0,20,5"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top">
                        <materialDesign:DialogHost HorizontalAlignment="Center"
                                                   VerticalAlignment="Top"
                                                   DialogClosing="DialogHost_Closed"
                                                   DialogTheme="Inherit">
                            <materialDesign:DialogHost.DialogContent>
                                <StackPanel Margin="16">
                                    <TextBlock>
                                        Add a new port to filter
                                    </TextBlock>
                                    <TextBox x:Name="PortText"
                                             Margin="0,8,0,0"
                                             HorizontalAlignment="Stretch"
                                             Style="{DynamicResource MaterialDesignFloatingHintTextBox}">
                                        <materialDesign:HintAssist.Hint>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="DoorOpen" />
                                                <TextBlock Text=" Port" />
                                            </StackPanel>
                                        </materialDesign:HintAssist.Hint>
                                    </TextBox>
                                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                        <Button Margin="0,8,8,0"
                                                Command="materialDesign:DialogHost.CloseDialogCommand"
                                                Cursor="Arrow"
                                                IsDefault="True"
                                                Style="{StaticResource MaterialDesignFlatButton}">
                                            <Button.CommandParameter>
                                                <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">
                                                    True
                                                </system:Boolean>
                                            </Button.CommandParameter>
                                            ADD
                                        </Button>
                                        <Button Margin="0,8,8,0"
                                                Command="materialDesign:DialogHost.CloseDialogCommand"
                                                Cursor="Arrow"
                                                IsCancel="True"
                                                Style="{StaticResource MaterialDesignFlatButton}">
                                            <Button.CommandParameter>
                                                <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">
                                                    False
                                                </system:Boolean>
                                            </Button.CommandParameter>
                                            CANCEL
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:DialogHost.DialogContent>
                            <Border MinWidth="256"
                                    MinHeight="256"
                                    VerticalAlignment="Top"
                                    BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                    BorderThickness="1"
                                    ClipToBounds="True"
                                    Visibility="Visible">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ListBox x:Name="PortListBox">
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Click="DeletePortItem_Click">
                                                    <MenuItem.Icon>
                                                        <materialDesign:PackIcon Kind="TrashOutline" />
                                                    </MenuItem.Icon>
                                                    <MenuItem.Header>
                                                        <TextBlock>Delete port</TextBlock>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                                <MenuItem Click="CopyPortItem_Click">
                                                    <MenuItem.Icon>
                                                        <materialDesign:PackIcon Kind="ClipboardOutline" />
                                                    </MenuItem.Icon>
                                                    <MenuItem.Header>
                                                        <TextBlock>Copy Port</TextBlock>
                                                    </MenuItem.Header>
                                                </MenuItem>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                    </ListBox>
                                    <Button Grid.Row="0"
                                            Margin="0,0,28,-20"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Command="{x:Static materialDesign:DialogHost.OpenDialogCommand}"
                                            Cursor="Arrow"
                                            Style="{StaticResource MaterialDesignFloatingActionMiniAccentButton}">
                                        <materialDesign:PackIcon Width="22"
                                                                 Height="22"
                                                                 Kind="Plus" />
                                    </Button>
                                    <Grid Grid.Row="1">
                                        <StackPanel Grid.Row="0"
                                                    Margin="15,0,0,0"
                                                    Orientation="Horizontal">
                                            <ToggleButton Name="InvertPortFilterToggle"
                                                          Cursor="Arrow"
                                                          Style="{DynamicResource MaterialDesignSwitchToggleButton}" />
                                            <TextBlock Margin="10,16,0,16" Foreground="White">
                                                Invert filter
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </materialDesign:DialogHost>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>