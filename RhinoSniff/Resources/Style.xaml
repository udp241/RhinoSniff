<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        RhinoSniffWindowBorder: the outer window-chrome border. BorderBrush + BorderThickness
        are intentionally NOT set here — ThemeManager.StampWindowBorder assigns them directly
        on each Window's Border element so nothing in the WPF style/resource system can compete
        with the user's accent pick (DynamicResource re-evaluation on layout passes, screenshot
        overlays, DPI changes, etc.). The only thing this style does is apply a Margin when
        the window is maximized so Windows' invisible resize frame doesn't clip our border.
    -->
    <Style x:Key="RhinoSniffWindowBorder" TargetType="Border">
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}}, Path=WindowState}" Value="Maximized">
                <Setter Property="Margin" Value="6" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="RhinoSniffTitleWhite" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Cascadia Code" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style x:Key="RhinoSniffTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Cascadia Code" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground">
            <Setter.Value>
                <LinearGradientBrush MappingMode="RelativeToBoundingBox" StartPoint="0.5,0" EndPoint="0.5,1">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterX="0.5" CenterY="0.5" />
                            <SkewTransform CenterX="0.5" CenterY="0.5" />
                            <RotateTransform Angle="88" CenterX="0.5" CenterY="0.5" />
                            <TranslateTransform />
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <LinearGradientBrush.Transform>
                        <RotateTransform CenterX="90" CenterY="90" />
                    </LinearGradientBrush.Transform>
                    <GradientStop Offset="1" Color="#FF00695C" />
                    <GradientStop Offset="0" Color="#FF00BFA5" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="RhinoSniffMuted" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextDim}" />
    </Style>
    <Style x:Key="RhinoSniffText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style x:Key="RhinoSniffBoldText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham Bold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style x:Key="RhinoSniffBadge" TargetType="Border">
        <Setter Property="CornerRadius" Value="10,10,10,10" />
        <Setter Property="Background" Value="White" />
        <Setter Property="Width" Value="50" />
        <Setter Property="Height" Value="20" />
    </Style>
    <Style x:Key="RhinoSniffSubtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
    <Style x:Key="RhinoSniffTiny" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Pill-style ToggleButton (used by Network Monitor tabs + Source sub-row).
         Overrides MaterialDesignThemes' default circular ToggleButton template
         that renders as white circle stubs. -->
    <Style x:Key="RhinoPillToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="pack://application:,,,/RhinoSniff;Component/Resources/Fonts/#Gotham" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="PillBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="14"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource AccentTealDark}" />
                            <Setter TargetName="PillBorder" Property="BorderBrush" Value="{DynamicResource AccentTealDark}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PillBorder" Property="BorderBrush" Value="{DynamicResource AccentTeal}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Smaller variant of RhinoPillToggle for sub-row source toggles (Packet Filters / PSN / XBOX) -->
    <Style x:Key="RhinoPillToggleSmall" TargetType="ToggleButton" BasedOn="{StaticResource RhinoPillToggle}">
        <Setter Property="Height" Value="22" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="PillBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="11"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextElement.FontWeight="{TemplateBinding FontWeight}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource AccentTealDark}" />
                            <Setter TargetName="PillBorder" Property="BorderBrush" Value="{DynamicResource AccentTealDark}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PillBorder" Property="BorderBrush" Value="{DynamicResource AccentTeal}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>