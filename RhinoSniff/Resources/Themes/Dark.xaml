<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Window / app surfaces (opaque) -->
    <SolidColorBrush x:Key="WindowBg" Color="#FF14141E" />
    <SolidColorBrush x:Key="AppBg" Color="#FF0A0A14" />
    <SolidColorBrush x:Key="GridBg" Color="#FF0A0A14" />

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBg" Color="#FF0D0D16" />
    <SolidColorBrush x:Key="SidebarBgAlpha" Color="#990D0D16" />
    <SolidColorBrush x:Key="SidebarBorder" Color="#FF1A1A28" />
    <SolidColorBrush x:Key="SidebarAdapterBg" Color="#FF0A0A12" />
    <SolidColorBrush x:Key="SidebarAdapterBgAlpha" Color="#990A0A12" />
    <SolidColorBrush x:Key="SidebarSubItemBg" Color="#FF08080F" />

    <!-- Top title bar -->
    <SolidColorBrush x:Key="TopBoxBg" Color="#7F0A0A14" />
    <SolidColorBrush x:Key="TopBoxBgAlpha" Color="#600A0A14" />

    <!-- Stats bar -->
    <SolidColorBrush x:Key="StatsBarBg" Color="#FF0C0C16" />
    <SolidColorBrush x:Key="StatsBarBgAlpha" Color="#990C0C16" />

    <!-- Search bar -->
    <SolidColorBrush x:Key="SearchBarBg" Color="#FF0E0E18" />
    <SolidColorBrush x:Key="SearchBarBgAlpha" Color="#990E0E18" />
    <SolidColorBrush x:Key="SearchBoxBg" Color="#FF1A1A28" />
    <SolidColorBrush x:Key="SearchBoxBgAlpha" Color="#991A1A28" />
    <SolidColorBrush x:Key="SearchBoxBorder" Color="#FF2A2A35" />

    <!-- Grid -->
    <SolidColorBrush x:Key="GridRowAltAlpha" Color="#800A0A14" />

    <!-- Tab control -->
    <SolidColorBrush x:Key="TabControlBg" Color="#FF0A0A14" />
    <SolidColorBrush x:Key="TabInactiveBg" Color="#FF151520" />
    <SolidColorBrush x:Key="TabInactiveBorder" Color="#FF2A2A35" />
    <SolidColorBrush x:Key="TabInactiveText" Color="#66FFFFFF" />

    <!-- Bottom status bar -->
    <SolidColorBrush x:Key="BottomStatusBg" Color="#FF0A0A14" />
    <SolidColorBrush x:Key="BottomStatusBgAlpha" Color="#990A0A14" />
    <SolidColorBrush x:Key="BottomStatusBorder" Color="#1AFFFFFF" />

    <!-- Dividers -->
    <SolidColorBrush x:Key="Divider" Color="#FF1A1A28" />
    <SolidColorBrush x:Key="DividerSoft" Color="#1AFFFFFF" />

    <!-- Text (graduated opacity) -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextSecondary" Color="#CCFFFFFF" />
    <SolidColorBrush x:Key="TextMuted" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="TextFaint" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="TextDim" Color="#44FFFFFF" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFFFF" />

    <!-- Sidebar item states -->
    <SolidColorBrush x:Key="SidebarItemActive" Color="#FF00BFA5" />
    <SolidColorBrush x:Key="SidebarItemInactive" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="SidebarItemHover" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="SidebarItemSelectedBg" Color="#1A00BFA5" />

    <!-- Packet type pill (badge in grid) -->
    <SolidColorBrush x:Key="PacketTypePillBg" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="PacketTypePillBorder" Color="#33FFFFFF" />

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBg" Color="#FF1A1A28" />
    <SolidColorBrush x:Key="InputBorder" Color="#FF2A2A35" />
    <SolidColorBrush x:Key="InputBorderFocus" Color="#FF00BFA5" />

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBg" Color="#FF151520" />
    <SolidColorBrush x:Key="CardBgHover" Color="#FF1A1A28" />
    <SolidColorBrush x:Key="CardBorder" Color="#FF2A2A35" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarTrack" Color="#FF0A0A14" />
    <SolidColorBrush x:Key="ScrollbarThumb" Color="#33FFFFFF" />

    <!-- Legacy side-view / overlay surfaces -->
    <SolidColorBrush x:Key="SideViewBg" Color="#FF14141E" />
    <SolidColorBrush x:Key="SideViewHeaderBg" Color="#FF07070F" />
    <SolidColorBrush x:Key="SideViewBgAlpha" Color="#4414141E" />
    <SolidColorBrush x:Key="NotificationBg" Color="#7F0A0A14" />

    <!-- Row overlay surfaces (legacy views) -->
    <SolidColorBrush x:Key="RowSurfaceSoft" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="RowSurfaceStrong" Color="#FF151520" />

    <!-- Toolbar Sniff/ARP idle/active states (Phase 7.1.5 — replaces hex literals) -->
    <SolidColorBrush x:Key="ToolbarBtnIdleBg" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="ToolbarBtnDangerBg" Color="#44B71C1C" />
</ResourceDictionary>
