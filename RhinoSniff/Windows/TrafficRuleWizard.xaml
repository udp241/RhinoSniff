<UserControl x:Class="RhinoSniff.Windows.TrafficRuleWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="560"
        FontFamily="{DynamicResource AppFontFamily}"
        Background="Transparent"
        d:DesignHeight="600" d:DesignWidth="560">

    <Border CornerRadius="8" Padding="0" BorderThickness="1"
            BorderBrush="{DynamicResource Divider}"
            Background="{DynamicResource CardBg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /><!-- title bar -->
                <RowDefinition Height="*" />   <!-- body -->
                <RowDefinition Height="Auto" /><!-- footer -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ════════════════════════════════════════════ -->
            <Border Grid.Row="0" Padding="20,16,20,12"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Create Traffic Rule" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="24" Height="24" Padding="0" Cursor="Hand"
                            Background="Transparent" BorderBrush="{x:Null}"
                            Click="Close_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextFaint}" />
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ BODY ═════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Padding="20,16">
                <Grid>
                    <!-- Step 0: Mode Selection -->
                    <StackPanel x:Name="PanelModeSelect" Visibility="Visible">
                        <TextBlock Text="How do you want to create this rule?" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" />
                        <UniformGrid Columns="2" Margin="0,0,0,0">
                            <!-- Custom -->
                            <Border x:Name="ModeCustomBtn" Margin="0,0,6,0" Padding="14,12"
                                    CornerRadius="6" Cursor="Hand"
                                    BorderThickness="1" MouseLeftButtonDown="ModeCustom_Click">
                                <StackPanel>
                                    <TextBlock Text="Custom" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="Manually choose target, protocol, ports, and action"
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <!-- Filters -->
                            <Border x:Name="ModeFilterBtn" Margin="6,0,0,0" Padding="14,12"
                                    CornerRadius="6" Cursor="Hand"
                                    BorderThickness="1" MouseLeftButtonDown="ModeFilter_Click">
                                <StackPanel>
                                    <TextBlock Text="Filters" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="Use Game Filters (DPI) for high-accuracy matching"
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFaint}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- Step 1a: Target (Custom) -->
                    <StackPanel x:Name="PanelTargetCustom" Visibility="Collapsed">
                        <!-- Stepper -->
                        <ContentControl x:Name="StepperHost1" Margin="0,0,0,16" />

                        <TextBlock Text="What would you like to target?" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />

                        <!-- All Traffic / Specific IPs -->
                        <UniformGrid Columns="2" Margin="0,0,0,10">
                            <Border x:Name="TargetAllBtn" Margin="0,0,6,0" Padding="10,8"
                                    CornerRadius="6" Cursor="Hand" BorderThickness="2"
                                    MouseLeftButtonDown="TargetAll_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Web" Width="18" Height="18"
                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                        Foreground="{DynamicResource TextSecondary}" />
                                    <StackPanel>
                                        <TextBlock Text="All Traffic" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Affect all network traffic" FontSize="10"
                                                   Foreground="{DynamicResource TextFaint}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border x:Name="TargetIpsBtn" Margin="6,0,0,0" Padding="10,8"
                                    CornerRadius="6" Cursor="Hand" BorderThickness="2"
                                    MouseLeftButtonDown="TargetIps_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="IpOutline" Width="18" Height="18"
                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                        Foreground="{DynamicResource TextSecondary}" />
                                    <StackPanel>
                                        <TextBlock Text="Specific IPs" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" />
                                        <TextBlock Text="Target one or more IPs" FontSize="10"
                                                   Foreground="{DynamicResource TextFaint}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- IP input (only visible when Specific IPs selected) -->
                        <StackPanel x:Name="IpInputPanel" Visibility="Collapsed" Margin="0,0,0,10">
                            <TextBlock Text="Target IP Addresses" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                            <!-- IP pills -->
                            <WrapPanel x:Name="IpPillsPanel" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="IpInput" Grid.Column="0" Padding="8,6"
                                         FontSize="12" materialDesign:HintAssist.Hint="Type IP and press Enter..."
                                         KeyDown="IpInput_KeyDown"
                                         Background="{DynamicResource InputBg}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource Divider}" />
                                <Button Grid.Column="1" Content="Add IP" Height="28" Padding="10,0"
                                        Margin="6,0,0,0" Cursor="Hand"
                                        materialDesign:ButtonAssist.CornerRadius="4"
                                        Click="AddIp_Click"
                                        Background="{DynamicResource AccentBlue}"
                                        Foreground="{DynamicResource TextOnAccent}"
                                        Style="{StaticResource MaterialDesignFlatButton}" />
                            </Grid>
                        </StackPanel>

                        <!-- Protocol -->
                        <TextBlock Text="Protocol" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                        <UniformGrid x:Name="ProtocolBar" Columns="3" Margin="0,0,0,10" />

                        <!-- Direction -->
                        <TextBlock Text="Direction" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                        <UniformGrid x:Name="DirectionBar" Columns="3" Margin="0,0,0,10" />

                        <!-- Ports -->
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6">
                            <Run Text="Ports " FontWeight="SemiBold" /><Run Text="(optional - leave empty for all)" />
                        </TextBlock>
                        <WrapPanel x:Name="PortPillsPanel" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PortInput" Grid.Column="0" Padding="8,6" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g. 3074 or 80-999"
                                     KeyDown="PortInput_KeyDown"
                                     Background="{DynamicResource InputBg}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource Divider}" />
                            <Button Grid.Column="1" Content="Add" Height="28" Padding="10,0"
                                    Margin="6,0,0,0" Cursor="Hand"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Click="AddPort_Click"
                                    Background="{DynamicResource AccentBlue}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}" />
                        </Grid>
                        <TextBlock Text="Use either explicit ports or a range (e.g. 80-999). Leave empty for all ports."
                                   FontSize="10" Foreground="{DynamicResource TextFaint}" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Step 1b: Filter Selection -->
                    <StackPanel x:Name="PanelTargetFilter" Visibility="Collapsed">
                        <TextBlock Text="Select a filter" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
                        <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,10"
                                BorderThickness="1" BorderBrush="{DynamicResource AccentBlue}">
                            <TextBlock FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource TextFaint}">
                                <Run Text="This selects a filter condition for a Traffic Control rule. To add/remove Game Filters for the Network/Filtered tab, use the Filters page." />
                            </TextBlock>
                        </Border>

                        <!-- My Filters tab + search (Official removed - no community filter system) -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="FilterTabMine" Grid.Column="0" CornerRadius="4" Padding="10,4"
                                    Cursor="Hand" Margin="0,0,8,0">
                                <TextBlock Text="My Filters" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                            <TextBox x:Name="FilterSearch" Grid.Column="1" Padding="8,4" FontSize="11"
                                     materialDesign:HintAssist.Hint="Search filters..."
                                     TextChanged="FilterSearch_Changed"
                                     Background="{DynamicResource InputBg}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource Divider}" />
                        </Grid>

                        <!-- Filter cards list -->
                        <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="FilterCardList" />
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Step 2: Action Selection -->
                    <StackPanel x:Name="PanelAction" Visibility="Collapsed">
                        <ContentControl x:Name="StepperHost2" Margin="0,0,0,16" />
                        <TextBlock Text="What action should be applied?" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />
                        <StackPanel x:Name="ActionCardList" />
                    </StackPanel>

                    <!-- Step 3: Settings -->
                    <StackPanel x:Name="PanelSettings" Visibility="Collapsed">
                        <ContentControl x:Name="StepperHost3" Margin="0,0,0,16" />
                        <TextBlock Text="Configure settings" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" />

                        <!-- Probability -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Probability" FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                    Background="{DynamicResource AccentBlue}">
                                <TextBlock x:Name="ProbLabel" Text="100%" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextOnAccent}" />
                            </Border>
                        </Grid>
                        <Slider x:Name="ProbSlider" Minimum="0" Maximum="100" Value="100"
                                IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="ProbSlider_Changed" Margin="0,0,0,2" />
                        <TextBlock Text="Chance to apply action to each packet" FontSize="10"
                                   Foreground="{DynamicResource TextFaint}" Margin="0,0,0,12" />

                        <!-- Burst Mode -->
                        <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                                Background="{DynamicResource InputBg}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Burst Mode" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="Apply action in ON/OFF cycles" FontSize="10"
                                               Foreground="{DynamicResource TextFaint}" />
                                </StackPanel>
                                <ToggleButton x:Name="BurstToggle" Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Checked="BurstToggle_Changed" Unchecked="BurstToggle_Changed"
                                              Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                            </Grid>
                        </Border>

                        <!-- Burst ON/OFF sliders (shown when burst enabled) -->
                        <StackPanel x:Name="BurstPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ON Duration (ms)" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}" Margin="0,0,16,0">
                                    <TextBlock x:Name="BurstOnLabel" Text="500ms" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                                <TextBlock Grid.Column="2" Text="OFF Duration (ms)" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="3" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}">
                                    <TextBlock x:Name="BurstOffLabel" Text="2000ms" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                            </Grid>
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="BurstOnSlider" Grid.Column="0" Minimum="50" Maximum="5000"
                                        Value="500" IsSnapToTickEnabled="True" TickFrequency="50"
                                        ValueChanged="BurstOn_Changed" Margin="0,0,8,0" />
                                <Slider x:Name="BurstOffSlider" Grid.Column="1" Minimum="50" Maximum="10000"
                                        Value="2000" IsSnapToTickEnabled="True" TickFrequency="50"
                                        ValueChanged="BurstOff_Changed" Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>

                        <!-- Action-specific: Delay + Jitter (Lag) -->
                        <StackPanel x:Name="LagPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Delay" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}" Margin="0,0,16,0">
                                    <TextBlock x:Name="DelayLabel" Text="100ms" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                                <TextBlock Grid.Column="2" Text="Jitter (±ms)" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="3" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}">
                                    <TextBlock x:Name="JitterLabel" Text="±0ms" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                            </Grid>
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="DelaySlider" Grid.Column="0" Minimum="1" Maximum="5000" Value="100"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Delay_Changed" Margin="0,0,8,0" />
                                <Slider x:Name="JitterSlider" Grid.Column="1" Minimum="0" Maximum="2000" Value="0"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="Jitter_Changed" Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>

                        <!-- Action-specific: Rate Limit (Throttle) -->
                        <StackPanel x:Name="ThrottlePanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Rate Limit (kbps)" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}">
                                    <TextBlock x:Name="RateLabel" Text="1000 kbps" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                            </Grid>
                            <Slider x:Name="RateSlider" Minimum="1" Maximum="100000" Value="1000"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="Rate_Changed" Margin="0,0,0,10" />
                        </StackPanel>

                        <!-- Action-specific: Reorder % + Window (Reorder) -->
                        <StackPanel x:Name="ReorderPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Reorder %" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}" Margin="0,0,16,0">
                                    <TextBlock x:Name="ReorderPctLabel" Text="50%" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                                <TextBlock Grid.Column="2" Text="Reorder Window (ms)" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="3" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}">
                                    <TextBlock x:Name="ReorderWinLabel" Text="100ms" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                            </Grid>
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="ReorderPctSlider" Grid.Column="0" Minimum="0" Maximum="100" Value="50"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="ReorderPct_Changed" Margin="0,0,8,0" />
                                <Slider x:Name="ReorderWinSlider" Grid.Column="1" Minimum="10" Maximum="2000" Value="100"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="ReorderWin_Changed" Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>

                        <!-- Action-specific: Duplicate % + Delay (Duplicate) -->
                        <StackPanel x:Name="DuplicatePanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Duplicate %" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}" Margin="0,0,16,0">
                                    <TextBlock x:Name="DupPctLabel" Text="50%" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                                <TextBlock Grid.Column="2" Text="Delay" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Grid.Column="3" CornerRadius="4" Padding="6,2"
                                        Background="{DynamicResource AccentBlue}">
                                    <TextBlock x:Name="DupDelayLabel" Text="0ms" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccent}" />
                                </Border>
                            </Grid>
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="DupPctSlider" Grid.Column="0" Minimum="0" Maximum="100" Value="50"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="DupPct_Changed" Margin="0,0,8,0" />
                                <Slider x:Name="DupDelaySlider" Grid.Column="1" Minimum="0" Maximum="2000" Value="0"
                                        IsSnapToTickEnabled="True" TickFrequency="1"
                                        ValueChanged="DupDelay_Changed" Margin="8,0,0,0" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Step 4: Review -->
                    <StackPanel x:Name="PanelReview" Visibility="Collapsed">
                        <ContentControl x:Name="StepperHost4" Margin="0,0,0,16" />
                        <TextBlock Text="Review your rule" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />

                        <!-- Rule Name -->
                        <TextBlock FontSize="11" Margin="0,0,0,4">
                            <Run Text="Rule Name " FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" /><Run Text="*" Foreground="{DynamicResource ActionDrop}" />
                        </TextBlock>
                        <TextBox x:Name="RuleNameInput" Padding="8,6" FontSize="12" Margin="0,0,0,12"
                                 materialDesign:HintAssist.Hint="e.g., Lag Game Server"
                                 Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource Divider}" />

                        <!-- Summary table -->
                        <Border CornerRadius="6" BorderThickness="1"
                                BorderBrush="{DynamicResource Divider}" Padding="0">
                            <StackPanel x:Name="ReviewTable" />
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- ═══ FOOTER ═══════════════════════════════════════════════ -->
            <Border Grid.Row="2" Padding="20,12"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Cancel / Back -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="CancelBtn" Content="Cancel" Height="30" Padding="12,0"
                                Cursor="Hand" Click="Cancel_Click"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Background="{DynamicResource InputBg}"
                                Foreground="{DynamicResource TextSecondary}"
                                Style="{StaticResource MaterialDesignFlatButton}" />
                        <Button x:Name="BackBtn" Height="30" Padding="12,0" Margin="6,0,0,0"
                                Cursor="Hand" Click="Back_Click" Visibility="Collapsed"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Background="{DynamicResource InputBg}"
                                Foreground="{DynamicResource TextSecondary}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ChevronLeft" Width="14" Height="14"
                                    VerticalAlignment="Center" />
                                <TextBlock Text="Back" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Next / Create Rule -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="NextBtn" Height="30" Padding="12,0" Cursor="Hand"
                                Click="Next_Click" Visibility="Collapsed"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Background="{DynamicResource AccentBlue}"
                                Foreground="{DynamicResource TextOnAccent}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Next" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <materialDesign:PackIcon Kind="ChevronRight" Width="14" Height="14"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CreateBtn" Height="30" Padding="12,0" Cursor="Hand"
                                Click="Create_Click" Visibility="Collapsed"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Background="{DynamicResource StatusSuccess}"
                                Foreground="{DynamicResource TextOnAccent}"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Check" Width="14" Height="14"
                                    VerticalAlignment="Center" Margin="0,0,4,0" />
