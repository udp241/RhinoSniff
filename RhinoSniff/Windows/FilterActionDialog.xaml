<UserControl x:Class="RhinoSniff.Windows.FilterActionDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="500"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="Transparent"
             d:DesignHeight="380" d:DesignWidth="500">

    <Border CornerRadius="10" Padding="0" BorderThickness="1"
            BorderBrush="{DynamicResource CardBorder}"
            Background="{DynamicResource CardBg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Padding="24,18,24,14"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="TitleText" Text=""
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="What should happen when traffic matches?"
                                   FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="22" Height="22" Padding="0" Cursor="Hand"
                            Background="Transparent" BorderBrush="{x:Null}"
                            Click="Close_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"
                                                 Foreground="{DynamicResource TextFaint}" />
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ BODY: two option cards ═══════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="24,18,24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Highlight -->
                <Border x:Name="HighlightCard" Grid.Column="0" Padding="16,20"
                        CornerRadius="8" Cursor="Hand"
                        Background="{DynamicResource InputBg}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource CardBorder}"
                        MouseLeftButtonDown="Highlight_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="24"
                                Background="{DynamicResource HighlightTint}">
                            <materialDesign:PackIcon Kind="EyeOutline" Width="24" Height="24"
                                                     Foreground="{DynamicResource StatusSuccess}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Highlight" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,12,0,4" />
                        <TextBlock Text="Highlight matching traffic in the Filtered tab for review"
                                   FontSize="10" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                </Border>

                <!-- Discard -->
                <Border x:Name="DiscardCard" Grid.Column="2" Padding="16,20"
                        CornerRadius="8" Cursor="Hand"
                        Background="{DynamicResource InputBg}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource CardBorder}"
                        MouseLeftButtonDown="Discard_Click">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="24"
                                Background="{DynamicResource DiscardTint}">
                            <materialDesign:PackIcon Kind="EyeOffOutline" Width="24" Height="24"
                                                     Foreground="{DynamicResource StatusDanger}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Discard" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,12,0,4" />
                        <TextBlock Text="Discard matching traffic from all views"
                                   FontSize="10" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ FOOTER: Remove (left), Cancel + Apply (right) ══════════ -->
            <Border Grid.Row="2" Padding="24,14"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0">
                <Grid>
                    <Button x:Name="RemoveBtn" Content="Remove Filter"
                            HorizontalAlignment="Left"
                            Padding="16,8" FontSize="12" FontWeight="SemiBold"
                            Visibility="Collapsed"
                            Background="{DynamicResource StatusDanger}"
                            Foreground="{DynamicResource TextOnAccent}"
                            BorderBrush="{x:Null}"
                            materialDesign:ButtonAssist.CornerRadius="4"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Cursor="Hand"
                            Click="Remove_Click" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Padding="16,8" FontSize="12"
                                Background="{DynamicResource InputBg}"
                                Foreground="{DynamicResource TextPrimary}"
                                BorderBrush="{DynamicResource CardBorder}"
                                Margin="0,0,8,0"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Cursor="Hand"
                                Click="Close_Click" />
                        <Button x:Name="ApplyBtn" Content="Apply"
                                Padding="22,8" FontSize="12" FontWeight="SemiBold"
                                Background="{DynamicResource AccentTealDark}"
                                Foreground="{DynamicResource TextOnAccent}"
                                BorderBrush="{x:Null}"
                                materialDesign:ButtonAssist.CornerRadius="4"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Cursor="Hand"
                                Click="Apply_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
