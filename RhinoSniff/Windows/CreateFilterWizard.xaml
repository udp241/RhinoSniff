<UserControl x:Class="RhinoSniff.Windows.CreateFilterWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Width="560"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="Transparent"
             d:DesignHeight="640" d:DesignWidth="560">

    <Border CornerRadius="8" Padding="0" BorderThickness="1"
            BorderBrush="{DynamicResource Divider}"
            Background="{DynamicResource CardBg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- header -->
                <RowDefinition Height="Auto" /> <!-- step indicator -->
                <RowDefinition Height="*" />    <!-- body (scrolls) -->
                <RowDefinition Height="Auto" /> <!-- footer -->
            </Grid.RowDefinitions>

            <!-- ═══ HEADER ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Padding="24,18,24,14"
                    BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Create Packet Filter" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Create a new packet filter to capture specific network traffic."
                                   FontSize="11" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextMuted}" />
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                            Width="24" Height="24" Padding="0" Cursor="Hand"
                            Background="Transparent" BorderBrush="{x:Null}"
                            Click="Close_Click"
                            Style="{StaticResource MaterialDesignFlatButton}">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"
                                                 Foreground="{DynamicResource TextFaint}" />
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ STEP INDICATOR ══════════════════════════════════════════ -->
            <Border Grid.Row="1" Padding="24,14,24,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border x:Name="StepDot1" Width="24" Height="24" CornerRadius="12"
                            Background="{DynamicResource AccentTealDark}">
                        <TextBlock Text="1" Foreground="{DynamicResource TextOnAccent}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Rectangle x:Name="StepLine1" Width="60" Height="2" VerticalAlignment="Center"
                               Fill="{DynamicResource Divider}" Margin="6,0" />
                    <Border x:Name="StepDot2" Width="24" Height="24" CornerRadius="12"
                            Background="{DynamicResource InputBg}"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
                        <TextBlock Text="2" Foreground="{DynamicResource TextMuted}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Rectangle x:Name="StepLine2" Width="60" Height="2" VerticalAlignment="Center"
                               Fill="{DynamicResource Divider}" Margin="6,0" />
                    <Border x:Name="StepDot3" Width="24" Height="24" CornerRadius="12"
                            Background="{DynamicResource InputBg}"
                            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
                        <TextBlock Text="3" Foreground="{DynamicResource TextMuted}"
                                   FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══ BODY ═════════════════════════════════════════════════════ -->
            <!-- Padding on the inner Grid (Margin) rather than ScrollViewer — avoids scrollbar
                 eating into right padding, and gives consistent inset across all wizard steps. -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0">
                <Grid Margin="24,14,24,18">
                    <!-- ─── Step 1a: Source chooser ─── -->
                    <StackPanel x:Name="PanelStep1a" Visibility="Visible">
                        <TextBlock Text="Choose filter type" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Choose where this filter should live and how it should behave."
                                   FontSize="11" Margin="0,4,0,16"
                                   Foreground="{DynamicResource TextMuted}" />

                        <UniformGrid Columns="2">
                            <!-- Local -->
                            <Border x:Name="SourceLocalBtn" Margin="0,0,6,0" Padding="16,14"
                                    CornerRadius="8" Cursor="Hand"
                                    Background="{DynamicResource InputBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    MouseLeftButtonDown="SourceLocal_Click">
                                <StackPanel>
                                    <Border Width="36" Height="36" CornerRadius="6"
                                            Background="{DynamicResource FilterLocalTint}"
                                            HorizontalAlignment="Left">
                                        <materialDesign:PackIcon Kind="Harddisk" Width="20" Height="20"
                                                                 Foreground="{DynamicResource FilterLocalAccent}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Local Filter" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" Margin="0,10,0,4" />
                                    <TextBlock Text="Saved only on this device. Great for personal hide/show rules like port 443 or HTTP/HTTPS traffic."
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>
                            </Border>

                            <!-- Cloud -->
                            <Border x:Name="SourceCloudBtn" Margin="6,0,0,0" Padding="16,14"
                                    CornerRadius="8" Cursor="Hand"
                                    Background="{DynamicResource InputBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    MouseLeftButtonDown="SourceCloud_Click">
                                <StackPanel>
                                    <Border Width="36" Height="36" CornerRadius="6"
                                            Background="{DynamicResource FilterCloudTint}"
                                            HorizontalAlignment="Left">
                                        <materialDesign:PackIcon Kind="CloudOutline" Width="20" Height="20"
                                                                 Foreground="{DynamicResource FilterCloudAccent}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Cloud Filter" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" Margin="0,10,0,4" />
                                    <TextBlock Text="Saved to your account. You can optionally share it with the community."
                                               FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- ─── Step 1b-Local: Local filter form ─── -->
                    <StackPanel x:Name="PanelStep1bLocal" Visibility="Collapsed">
                        <Border Padding="12,8" CornerRadius="6" Margin="0,0,0,14"
                                Background="{DynamicResource InputBg}">
                            <TextBlock Text="Local filters stay on your device and never publish to the cloud."
                                       FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                        </Border>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}">
                                    <Run Text="Filter Name " /><Run Text="*" Foreground="{DynamicResource AccentTeal}" />
                                </TextBlock>
                                <TextBox x:Name="LocalNameBox" Margin="0,4,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                         materialDesign:HintAssist.Hint="e.g. My Filter" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}">
                                    <Run Text="Protocol " /><Run Text="*" Foreground="{DynamicResource AccentTeal}" />
                                </TextBlock>
                                <ComboBox x:Name="LocalProtocolBox" Margin="0,4,0,0" Padding="10,6"
                                          Background="{DynamicResource InputBg}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource Divider}" FontSize="12">
                                    <ComboBoxItem Content="UDP" IsSelected="True" />
                                    <ComboBoxItem Content="TCP" />
                                    <ComboBoxItem Content="BOTH" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="IP / CIDR" FontSize="11" Foreground="{DynamicResource TextPrimary}" />
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocalIpInput" Grid.Column="0" Padding="10,6"
                                     Background="{DynamicResource InputBg}"
                                     BorderBrush="{DynamicResource Divider}"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g. 8.8.8.8 or 192.168.1.0/24"
                                     KeyDown="LocalIp_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="14,0"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="AddLocalIp_Click" Cursor="Hand" />
                        </Grid>
                        <TextBlock Text="Match specific IPs or subnets (e.g. 8.8.8.8, 10.0.0.0/24)"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                        <WrapPanel x:Name="LocalIpChips" Margin="0,0,0,12" />

                        <TextBlock Text="Country" FontSize="11" Foreground="{DynamicResource TextPrimary}" />
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocalCountryInput" Grid.Column="0" Padding="10,6"
                                     Background="{DynamicResource InputBg}"
                                     BorderBrush="{DynamicResource Divider}"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g. US, DE, CA"
                                     KeyDown="LocalCountry_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="14,0"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="AddLocalCountry_Click" Cursor="Hand" />
                        </Grid>
                        <TextBlock Text="Match by 2-letter country code"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                        <WrapPanel x:Name="LocalCountryChips" Margin="0,0,0,12" />

                        <TextBlock Text="ISP" FontSize="11" Foreground="{DynamicResource TextPrimary}" />
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocalIspInput" Grid.Column="0" Padding="10,6"
                                     Background="{DynamicResource InputBg}"
                                     BorderBrush="{DynamicResource Divider}"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g. Cloudflare, Amazon"
                                     KeyDown="LocalIsp_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="14,0"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="AddLocalIsp_Click" Cursor="Hand" />
                        </Grid>
                        <TextBlock Text="Match by ISP name (partial match, case-insensitive)"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                        <WrapPanel x:Name="LocalIspChips" Margin="0,0,0,12" />

                        <TextBlock Text="Bytes Pattern (Hex)" FontSize="11" Foreground="{DynamicResource TextPrimary}" />
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocalBytesInput" Grid.Column="0" Padding="10,6"
                                     Background="{DynamicResource InputBg}"
                                     BorderBrush="{DynamicResource Divider}"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g. FF FF FF, AB CD 01"
                                     KeyDown="LocalBytes_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="14,0"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="AddLocalBytes_Click" Cursor="Hand" />
                        </Grid>
                        <TextBlock Text="Enter hex bytes. Use commas to separate multiple patterns. Example: FFFFFF, FF00"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                        <WrapPanel x:Name="LocalBytesChips" Margin="0,0,0,12" />

                        <TextBlock Text="Port Range" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,6,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="START (E.G., 3074)" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="LocalPortStart" Text="0" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="END (E.G., 3074)" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="LocalPortEnd" Text="65535" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Optional. Leave empty to match all ports."
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                        <TextBlock Text="Examples: port 443 (HTTPS), port 80 (HTTP). Create separate local filters if you want both."
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,10" />

                        <TextBlock Text="Packet Length Range" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MIN LENGTH" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="LocalLenMin" Text="0" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MAX LENGTH" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="LocalLenMax" Text="65535" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Optional. Specify packet size constraints in bytes."
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- ─── Step 1b-Cloud: Cloud filter form ─── -->
                    <StackPanel x:Name="PanelStep1bCloud" Visibility="Collapsed">
                        <TextBlock Text="Game (IGDB)" FontSize="11"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBox x:Name="CloudGameBox" Margin="0,4,0,4" Padding="10,6"
                                 Background="{DynamicResource InputBg}"
                                 BorderBrush="{DynamicResource Divider}"
                                 Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                 materialDesign:HintAssist.Hint="Search for a game..." />
                        <TextBlock Text="Optional. Link to a game for auto-filled metadata and cover art."
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,10" />

                        <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}">
                            <Run Text="Filter Name " /><Run Text="*" Foreground="{DynamicResource AccentTeal}" />
                        </TextBlock>
                        <TextBox x:Name="CloudNameBox" Margin="0,4,0,10" Padding="10,6"
                                 Background="{DynamicResource InputBg}"
                                 BorderBrush="{DynamicResource Divider}"
                                 Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                 materialDesign:HintAssist.Hint="e.g. My Filter" />

                        <TextBlock Text="Description" FontSize="11" Foreground="{DynamicResource TextPrimary}" />
                        <TextBox x:Name="CloudDescBox" Margin="0,4,0,10" Padding="10,6"
                                 Background="{DynamicResource InputBg}"
                                 BorderBrush="{DynamicResource Divider}"
                                 Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 materialDesign:HintAssist.Hint="Brief description of what this filter captures" />

                        <TextBlock Text="Title IDs" FontSize="11" Foreground="{DynamicResource TextPrimary}" />
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CloudTitleIdInput" Grid.Column="0" Padding="10,6"
                                     Background="{DynamicResource InputBg}"
                                     BorderBrush="{DynamicResource Divider}"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g., CUSA00001"
                                     KeyDown="CloudTitleId_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="14,0"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="AddCloudTitleId_Click" Cursor="Hand" />
                        </Grid>
                        <TextBlock Text="Optional game/application title IDs for automatic filter matching (max 10)"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                        <WrapPanel x:Name="CloudTitleIdChips" Margin="0,0,0,10" />

                        <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}">
                            <Run Text="Bytes Pattern (Hex)" /><Run Text="*" Foreground="{DynamicResource AccentTeal}" />
                        </TextBlock>
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CloudBytesInput" Grid.Column="0" Padding="10,6"
                                     Background="{DynamicResource InputBg}"
                                     BorderBrush="{DynamicResource Divider}"
                                     Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                     materialDesign:HintAssist.Hint="e.g., FF FF FF, AB CD 01"
                                     KeyDown="CloudBytes_KeyDown" />
                            <Button Grid.Column="1" Content="Add" Margin="8,0,0,0" Padding="14,0"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Click="AddCloudBytes_Click" Cursor="Hand" />
                        </Grid>
                        <TextBlock Text="Enter hex bytes. Use commas to separate multiple patterns. Example: FFFFFF, FF00"
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                        <WrapPanel x:Name="CloudBytesChips" Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}">
                                    <Run Text="Protocol " /><Run Text="*" Foreground="{DynamicResource AccentTeal}" />
                                </TextBlock>
                                <ComboBox x:Name="CloudProtocolBox" Margin="0,4,0,0" Padding="10,6"
                                          Background="{DynamicResource InputBg}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource Divider}" FontSize="12">
                                    <ComboBoxItem Content="UDP" IsSelected="True" />
                                    <ComboBoxItem Content="TCP" />
                                    <ComboBoxItem Content="BOTH" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Connection Type" FontSize="11"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <ComboBox x:Name="CloudConnectionBox" Margin="0,4,0,0" Padding="10,6"
                                          Background="{DynamicResource InputBg}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource Divider}" FontSize="12">
                                    <ComboBoxItem Content="None" IsSelected="True" />
                                    <ComboBoxItem Content="Matchmaking" />
                                    <ComboBoxItem Content="Party" />
                                    <ComboBoxItem Content="Session" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6">
                            <Run Text="Platforms " /><Run Text="*" Foreground="{DynamicResource AccentTeal}" />
                        </TextBlock>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox x:Name="PlatformPS3" Content="PS3" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformPS5" Content="PS5" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformXboxOne" Content="Xbox One" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformPC" Content="PC" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformIOS" Content="iOS" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformUniversal" Content="Universal" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox x:Name="PlatformPS4" Content="PS4" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformXbox360" Content="Xbox 360" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformXboxSeriesX" Content="Xbox Series X" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformMobile" Content="Mobile" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                                <CheckBox x:Name="PlatformAndroid" Content="Android" Margin="0,2"
                                          Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="PlatformsError" Text="At least one platform must be selected"
                                   FontSize="10" Foreground="{DynamicResource StatusDanger}"
                                   Margin="0,0,0,10" Visibility="Collapsed" />

                        <TextBlock Text="Port Range" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,6,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="START (E.G., 3074)" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="CloudPortStart" Text="0" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="END (E.G., 3074)" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="CloudPortEnd" Text="65535" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Optional. Leave empty to match all ports."
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,10" />

                        <TextBlock Text="Packet Length Range" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MIN LENGTH" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="CloudLenMin" Text="0" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MAX LENGTH" FontSize="9"
                                           Foreground="{DynamicResource TextMuted}" />
                                <TextBox x:Name="CloudLenMax" Text="65535" Margin="0,2,0,0" Padding="10,6"
                                         Background="{DynamicResource InputBg}"
                                         BorderBrush="{DynamicResource Divider}"
                                         Foreground="{DynamicResource TextPrimary}" FontSize="12" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Optional. Specify packet size constraints in bytes."
                                   FontSize="10" Foreground="{DynamicResource TextMuted}" Margin="0,4,0,10" />

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <CheckBox x:Name="ShareWithCommunityBox"
                                      Foreground="{DynamicResource TextPrimary}" Cursor="Hand" />
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="Share with community" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <TextBlock Text="Make this filter available to other users"
                                           FontSize="10" Foreground="{DynamicResource TextMuted}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- ─── Step 2: Action ─── -->
                    <StackPanel x:Name="PanelStep2" Visibility="Collapsed">
                        <TextBlock Text="What should happen when traffic matches?" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Choose what the software does when traffic matches this filter."
                                   FontSize="11" Margin="0,4,0,16"
                                   Foreground="{DynamicResource TextMuted}" />
                        <UniformGrid Columns="2">
                            <!-- Highlight -->
                            <Border x:Name="ActionHighlightBtn" Margin="0,0,6,0" Padding="16,18"
                                    CornerRadius="8" Cursor="Hand"
                                    Background="{DynamicResource InputBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    MouseLeftButtonDown="ActionHighlight_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="22"
                                            Background="{DynamicResource HighlightTint}">
                                        <materialDesign:PackIcon Kind="EyeOutline" Width="22" Height="22"
                                                                 Foreground="{DynamicResource StatusSuccess}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Highlight" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               HorizontalAlignment="Center" Margin="0,10,0,4" />
                                    <TextBlock Text="Highlight matching traffic in the Filtered tab for review"
                                               FontSize="10" TextWrapping="Wrap"
                                               HorizontalAlignment="Center" TextAlignment="Center"
                                               Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>
                            </Border>
                            <!-- Discard -->
                            <Border x:Name="ActionDiscardBtn" Margin="6,0,0,0" Padding="16,18"
                                    CornerRadius="8" Cursor="Hand"
                                    Background="{DynamicResource InputBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    MouseLeftButtonDown="ActionDiscard_Click">
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="22"
                                            Background="{DynamicResource DiscardTint}">
                                        <materialDesign:PackIcon Kind="EyeOffOutline" Width="22" Height="22"
                                                                 Foreground="{DynamicResource StatusDanger}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Discard" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               HorizontalAlignment="Center" Margin="0,10,0,4" />
                                    <TextBlock Text="Discard matching traffic from all views"
                                               FontSize="10" TextWrapping="Wrap"
                                               HorizontalAlignment="Center" TextAlignment="Center"
                                               Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <!-- ─── Step 3: Review ─── -->
                    <StackPanel x:Name="PanelStep3" Visibility="Collapsed">
                        <TextBlock Text="Review &amp; Save" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" />
                        <Border Padding="16" CornerRadius="6"
                                Background="{DynamicResource InputBg}"
                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                            <StackPanel x:Name="ReviewPanel" />
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- ═══ FOOTER ═══════════════════════════════════════════════════ -->
            <Border Grid.Row="3" Padding="24,14" BorderBrush="{DynamicResource Divider}" BorderThickness="0,1,0,0">
                <Grid>
                    <Button x:Name="BackBtn" Content="Back" HorizontalAlignment="Left"
                            Padding="18,8" FontSize="12"
                            Visibility="Collapsed"
                            Background="{DynamicResource InputBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource CardBorder}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="Back_Click" Cursor="Hand" />
                    <Button x:Name="CancelBtn" Content="Cancel" HorizontalAlignment="Left"
                            Padding="18,8" FontSize="12"
                            Background="{DynamicResource InputBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource CardBorder}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="Close_Click" Cursor="Hand" />
                    <Button x:Name="NextBtn" Content="Next" HorizontalAlignment="Right"
                            Padding="22,8" FontSize="12"
                            Visibility="Collapsed"
                            Background="{DynamicResource AccentTealDark}"
                            Foreground="{DynamicResource TextOnAccent}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="Next_Click" Cursor="Hand" />
                    <Button x:Name="CreateBtn" Content="Create Filter" HorizontalAlignment="Right"
                            Padding="22,8" FontSize="12"
                            Visibility="Collapsed"
                            Background="{DynamicResource AccentTealDark}"
                            Foreground="{DynamicResource TextOnAccent}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="Create_Click" Cursor="Hand" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
