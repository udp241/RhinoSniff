    <Border Name="Border" Style="{StaticResource RhinoSniffWindowBorder}">
        <materialDesign:DialogHost
            Grid.RowSpan="2"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            DialogClosing="DialogHost_DialogClosing"
            DialogTheme="Inherit"
            IsOpen="{Binding ElementName=Window, Path=IsDialogOpen}">
            <materialDesign:DialogHost.DialogContent>
                <StackPanel Margin="16">
                    <TextBlock>
                        Add a new label
                    </TextBlock>
                    <TextBox
                        x:Name="TextHost"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        Style="{DynamicResource MaterialDesignFloatingHintTextBox}">
                        <materialDesign:HintAssist.Hint>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Ip" />
                                <TextBlock Text=" IP Address" />
                            </StackPanel>
                        </materialDesign:HintAssist.Hint>
                    </TextBox>
                    <TextBox
                        x:Name="TextLabel"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch"
                        Style="{DynamicResource MaterialDesignFloatingHintTextBox}">
                        <materialDesign:HintAssist.Hint>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="LabelOutline" />
                                <TextBlock Text=" Label" />
                            </StackPanel>
                        </materialDesign:HintAssist.Hint>
                    </TextBox>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button
                            Margin="0,8,8,0"
                            Command="materialDesign:DialogHost.CloseDialogCommand"
                            Cursor="Arrow"
                            IsDefault="True"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <Button.CommandParameter>
                                <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">
                                    True
                                </system:Boolean>
                            </Button.CommandParameter>
                            ADD
                        </Button>
                        <Button
                            Margin="0,8,8,0"
                            Command="materialDesign:DialogHost.CloseDialogCommand"
                            Cursor="Arrow"
                            IsCancel="True"
                            Style="{StaticResource MaterialDesignFlatButton}">
                            <Button.CommandParameter>
                                <system:Boolean xmlns:system="clr-namespace:System;assembly=mscorlib">
                                    False
                                </system:Boolean>
                            </Button.CommandParameter>
                            CANCEL
                        </Button>
                    </StackPanel>
                </StackPanel>
            </materialDesign:DialogHost.DialogContent>
            <Grid Name="MainGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Image
                    Name="BackgroundImage"
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="3"
                    Width="{Binding ElementName=Window, Path=ActualWidth}"
                    Height="{Binding ElementName=Window, Path=ActualHeight}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Stretch="UniformToFill" />
                <Grid
                    Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" x:Name="TopBox"
                    Width="{Binding ElementName=MainGrid, Path=ActualWidth}"
                    Height="37"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource TopBoxBg}"
                    RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Button
                        x:Name="CloseButton"
                        Width="54"
                        Height="36"
                        Margin="1046,0,0,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{x:Static window:MainWindow.HandleCaptions}"
                        Cursor="Arrow"
                        Foreground="{DynamicResource TextPrimary}"
                        RenderTransformOrigin="0.5,0.5"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Button.RenderTransform>
                        <materialDesign:PackIcon Kind="WindowClose" />
                    </Button>
                    <Button
                        Name="MinButton"
                        Width="54"
                        Height="36"
                        Margin="938,0,110,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{x:Static window:MainWindow.HandleCaptions}"
                        Cursor="Arrow"
                        Foreground="{DynamicResource TextPrimary}"
                        RenderTransformOrigin="0.5,0.5"
                        ToolTip="Minimise RhinoSniff"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Button.RenderTransform>
                        <materialDesign:PackIcon Kind="WindowMinimize" />
                    </Button>
                    <Button
                        Name="MaxButton"
                        Width="54"
                        Height="36"
                        Margin="992,0,55,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{x:Static window:MainWindow.HandleCaptions}"
                        Cursor="Arrow"
                        Foreground="{DynamicResource TextPrimary}"
                        RenderTransformOrigin="0.5,0.5"
                        ToolTip="Maximize RhinoSniff"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Button.RenderTransform>
                        <materialDesign:PackIcon Name="MaxIcon" Kind="WindowMaximize" />
                    </Button>
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Image
                            Width="20"
                            Height="20"
                            Margin="0,0,7,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MouseDown="IconBox_MouseDown"
                            RenderTransformOrigin="0.5,0.5"
                            Source="/Resources/Images/rhinosniff-28.png"
                            ToolTip="RIP L"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <SkewTransform />
                                    <RotateTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                        <TextBlock
                            x:Name="WindowTitleText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5"
                            Style="{StaticResource RhinoSniffBoldText}"
                            Text="RhinoSniff - Idle">
                            <TextBlock.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <SkewTransform />
                                    <RotateTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <Rectangle
                    x:Name="Dimmer"
                    Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3"
                    Width="{Binding ElementName=Window, Path=Width}"
                    Height="{Binding ElementName=Window, Path=Height}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Fill="{DynamicResource DimmerOverlay}"
                    Opacity="0"
                    Visibility="Hidden"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    MouseDown="Dimmer_MouseDown" />

                <!-- ═══ Phase 8: Traffic Control wizard overlay ═══════════════════
                     Dim backdrop + centered modal host, both inside MainWindow so
                     the wizard naturally resizes with the parent and click-outside
                     dismisses it. -->
                <Grid x:Name="TcModalRoot"
                      Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3"
                      Visibility="Collapsed"
                      WindowChrome.IsHitTestVisibleInChrome="True"
                      Panel.ZIndex="1000">
                    <!-- Click-outside-to-close backdrop -->
                    <Rectangle x:Name="TcModalBackdrop" Fill="{DynamicResource DimmerOverlay}"
                               MouseDown="TcModalBackdrop_MouseDown" />
                    <!-- Centered wizard host. Width/height clamp to window so it
                         shrinks with the main window. ScrollViewer handles overflow. -->
                    <ContentControl x:Name="TcModalHost"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="640" MaxHeight="640"
                                    Margin="40" />
                </Grid>

                <!-- ═══ Phase 9: Filter wizard overlay ═══════════════════════════
                     Same pattern as TcModalRoot but for the Create Packet Filter wizard.
                     Separate element so the two never interfere. -->
                <Grid x:Name="FilterModalRoot"
                      Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3"
                      Visibility="Collapsed"
                      WindowChrome.IsHitTestVisibleInChrome="True"
                      Panel.ZIndex="1001">
                    <Rectangle x:Name="FilterModalBackdrop" Fill="{DynamicResource DimmerOverlay}"
                               MouseDown="FilterModalBackdrop_MouseDown" />
                    <ContentControl x:Name="FilterModalHost"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="720" MaxHeight="700"
                                    Margin="40" />
                </Grid>

                <!-- ═══ LEFT SIDEBAR ═══ -->
                <Border x:Name="SidebarBorder" Grid.Row="1" Grid.Column="0"
                        Background="{DynamicResource SidebarBg}"
                        BorderBrush="{DynamicResource SidebarBorder}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Brand header + collapse toggle -->
                        <Grid Grid.Row="0" Margin="10,10,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel x:Name="SidebarBrandPanel" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Image Source="pack://application:,,,/RhinoSniff;Component/Resources/Images/rhinosniff-28.png"
                                       Width="22" Height="22" Margin="0,0,8,0" />
                                <TextBlock Text="RhinoSniff" FontWeight="SemiBold" FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Border Background="{DynamicResource SidebarItemSelectedBg}"
                                        CornerRadius="3" Padding="4,1" Margin="6,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="SidebarVersionPill" Text="v2" FontSize="9"
                                               Foreground="{DynamicResource SidebarItemActive}" />
                                </Border>
                            </StackPanel>
                            <Button x:Name="SidebarCollapseButton" Grid.Column="1"
                                    Width="24" Height="24"
                                    Background="Transparent" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource TextMuted}"
                                    Cursor="Hand"
                                    Padding="0"
                                    Click="SidebarCollapseButton_Click"
                                    ToolTip="Collapse sidebar"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <materialDesign:PackIcon x:Name="SidebarCollapseIcon" Kind="ChevronLeft" Width="16" Height="16" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,0">
                            <!-- Adapter selector (functional — stays wired to capture) -->
                            <ComboBox
                                x:Name="NetworkAdapterComboBox"
                                Height="44"
                                Margin="10,0,10,8"
                                Foreground="{DynamicResource TextPrimary}"
                                FontSize="11"
                                IsEnabled="{Binding IsSniffing, Converter={StaticResource InverseBooleanConverter}, ElementName=Window}"
                                SelectionChanged="NetworkAdapterComboBox_SelectionChanged"
                                Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                ToolTip="Pick a network adapter">
                                <materialDesign:HintAssist.Hint>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="NetworkOutline" Width="14" Height="14" />
                                        <TextBlock Text=" Adapter" FontSize="11" />
                                    </StackPanel>
                                </materialDesign:HintAssist.Hint>
                                <ComboBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ComboBox.ItemsPanel>
                            </ComboBox>

                            <!-- Sniff + ARP buttons -->
                            <StackPanel x:Name="SidebarActionButtons" Margin="10,0,10,12">
                                <Button x:Name="SniffButton"
                                        Height="34"
                                        HorizontalAlignment="Stretch"
                                        materialDesign:ButtonAssist.CornerRadius="4"
                                        Command="{x:Static window:MainWindow.ToggleCapture}"
                                        Cursor="Arrow"
                                        Background="{DynamicResource AccentTealDark}" Foreground="{DynamicResource TextOnAccent}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        ToolTip="Start / stop capturing traffic">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="SniffIcon" Kind="Play" Width="14" Height="14" Margin="0,0,6,0" />
                                        <TextBlock x:Name="SniffText" Text="SNIFF" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                                <Button x:Name="ArpToggleButton"
                                        Height="34"
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Stretch"
                                        materialDesign:ButtonAssist.CornerRadius="4"
                                        Click="ArpToggleButton_Click"
                                        Cursor="Arrow"
                                        Background="{DynamicResource SidebarItemHover}" Foreground="{DynamicResource TextPrimary}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        ToolTip="Start or stop ARP poisoning"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="ArpToggleIcon" Kind="Play" Width="14" Height="14" Margin="0,0,6,0" />
                                        <TextBlock x:Name="ArpToggleText" Text="START ARP" FontSize="12" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Rectangle Height="1" Fill="{DynamicResource Divider}" Margin="10,0,10,8" />

                            <!-- Nav items -->
                            <Button x:Name="NavNetworkButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemActive}"
                                    Click="NavNetwork_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Network Monitor">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="NetworkOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                    <TextBlock x:Name="NavNetworkLabel" Text="Network" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Filters (expandable) -->
                            <Button x:Name="FilterButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="FilterButton_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Filters">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FilterOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                        <TextBlock x:Name="NavFilterLabel" Text="Filters" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <materialDesign:PackIcon x:Name="FilterChevron" Grid.Column="1" Kind="ChevronDown" Width="14" Height="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <StackPanel x:Name="FilterSubItems" Visibility="Collapsed" Background="{DynamicResource SidebarSubItemBg}">
                                <Button x:Name="NavPacketFiltersButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavPacketFilters_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="Packet Filters" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                                <Button x:Name="NavIspFiltersButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavIspFilters_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="ISP Filters" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                                <Button x:Name="NavDeviceFiltersButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavDeviceFilters_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="Device Filters" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>

                            <Button x:Name="ArpButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="NavArp_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="ARP Spoofing">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SkullCrossbonesOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                    <TextBlock x:Name="NavArpLabel" Text="ARP Spoofing" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Traffic Control (Phase 8) -->
                            <Button x:Name="NavTrafficControlButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="NavTrafficControl_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Traffic Control">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="SpeedometerSlow" Width="18" Height="18" Margin="0,0,10,0" />
                                        <TextBlock x:Name="NavTcLabel" Text="Traffic Control" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <!-- Live running indicator — shown when the engine is active -->
                                    <Ellipse x:Name="NavTcRunningDot" Grid.Column="1" Width="8" Height="8"
                                             Fill="{DynamicResource StatusSuccess}"
                                             VerticalAlignment="Center" Margin="0,0,2,0"
                                             Visibility="Collapsed" />
                                </Grid>
                            </Button>

                            <!-- Hotspot (Phase 5) -->
                            <Button x:Name="NavHotspotButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="NavHotspot_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Hotspot">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccessPoint" Width="18" Height="18" Margin="0,0,10,0" />
                                    <TextBlock x:Name="NavHotspotLabel" Text="Hotspot" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Tools (expandable) -->
                            <Button x:Name="ToolsButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="ToolsButton_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Tools">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ToolboxOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                        <TextBlock x:Name="NavToolsLabel" Text="Tools" FontSize="12" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <materialDesign:PackIcon x:Name="ToolsChevron" Grid.Column="1" Kind="ChevronDown" Width="14" Height="14" VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                            <StackPanel x:Name="ToolsSubItems" Visibility="Collapsed" Background="{DynamicResource SidebarSubItemBg}">
                                <Button x:Name="NavGeoIpButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavGeoIp_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="Geo IP Lookup" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                                <Button x:Name="NavNmapButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavNmap_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="Nmap Scanner" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                                <Button x:Name="NavPingButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavPing_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="Ping" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                                <Button x:Name="NavPacketTesterButton" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Padding="40,0,16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                        Foreground="{DynamicResource SidebarItemInactive}"
                                        Click="NavPacketTester_Click"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="Packet Tester" FontSize="11" VerticalAlignment="Center" />
                                </Button>
                            </StackPanel>

                            <!-- IP Storage (Phase 5) -->
                            <Button x:Name="NavIpStorageButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="NavIpStorage_Click"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="IP Storage">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                    <TextBlock x:Name="NavIpStorageLabel" Text="IP Storage" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Hotkeys sidebar entry removed in Phase 6 — accessible via Settings → Hotkeys -->

                            <!-- FAQ -->
                            <Button x:Name="NavFaqButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Click="NavStub_Click" Tag="FAQ (coming soon)"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="FAQ">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="HelpCircleOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                    <TextBlock x:Name="NavFaqLabel" Text="FAQ" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="SettingsButton" Height="36" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Padding="16,0" Cursor="Arrow" Background="{x:Null}" BorderBrush="{x:Null}"
                                    Foreground="{DynamicResource SidebarItemInactive}"
                                    Command="{x:Static window:MainWindow.OpenSettings}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Settings">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="SettingsOutline" Width="18" Height="18" Margin="0,0,10,0" />
                                    <TextBlock x:Name="NavSettingsLabel" Text="Settings" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        </ScrollViewer>

                        <!-- Bottom: adapter indicator -->
                        <Border x:Name="SidebarAdapterBorder" Grid.Row="2" Padding="12,8"
                                Background="{DynamicResource SidebarAdapterBg}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource SidebarItemActive}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="SidebarAdapterText" Text="No adapter" FontSize="10"
                                           Foreground="{DynamicResource TextFaint}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="140" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Grid.Column="1">
                    <!-- ═══ NETWORK MONITOR VIEW ═══ -->
                    <Grid x:Name="NetworkMonitorView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <!-- ═══ CONTENT HEADER: Network Monitor + status pill + actions ═══ -->
                <Border Grid.Row="0" Background="{DynamicResource AppBg}" Padding="14,10,14,10"
                        BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Network Monitor"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center" />

                        <!-- STOPPED / CAPTURING pill -->
                        <Border x:Name="CaptureStatusPill" Grid.Column="1"
                                Background="{DynamicResource PillStoppedBg}"
                                CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="CaptureStatusDot" Width="6" Height="6"
                                         Fill="{DynamicResource PillStoppedText}"
                                         Margin="0,0,5,0" VerticalAlignment="Center" />
                                <TextBlock x:Name="CaptureStatusText" Text="STOPPED"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="{DynamicResource PillStoppedText}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Right-aligned action buttons -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="HeaderSniffButton"
                                    Height="30" Margin="0,0,6,0" Padding="12,0"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Command="{x:Static window:MainWindow.ToggleCapture}"
                                    Cursor="Hand"
                                    Background="{DynamicResource AccentTealDark}"
                                    Foreground="{DynamicResource TextOnAccent}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    ToolTip="Start / stop capturing traffic">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="HeaderSniffIcon" Kind="Play" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock x:Name="HeaderSniffText" Text="Start Sniff" FontSize="11" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Height="30" Margin="0,0,6,0" Padding="12,0"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Command="{x:Static window:MainWindow.ClearAllCommand}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource TextMuted}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    ToolTip="Clear all captured data">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Broom" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Clear" FontSize="11" />
                                </StackPanel>
                            </Button>
                            <Button Height="30" Padding="12,0"
                                    materialDesign:ButtonAssist.CornerRadius="4"
                                    Command="{x:Static window:MainWindow.ExportCommand}"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource CardBorder}"
                                    BorderThickness="1"
                                    Foreground="{DynamicResource TextMuted}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    ToolTip="Export captured data to CSV">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FileExportOutline" Width="14" Height="14" Margin="0,0,5,0" />
                                    <TextBlock Text="Export" FontSize="11" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ PILL TAB ROW: All Traffic / Filtered Traffic ═══ -->
                <Border Grid.Row="1" Background="{DynamicResource AppBg}"
                        Padding="14,8,14,8"
                        BorderBrush="{DynamicResource Divider}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="AllTrafficTab"
                                      Style="{StaticResource RhinoPillToggle}"
                                      IsChecked="True"
                                      Margin="0,0,6,0"
                                      Click="AllTrafficTab_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="AllTrafficTabText" Text="All Traffic" VerticalAlignment="Center" />
                                <Border x:Name="AllTrafficTabBadge" Margin="8,0,0,0"
                                        Background="#33FFFFFF" CornerRadius="8" Padding="6,1"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="AllTrafficTabCount" Text="0"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                </Border>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton x:Name="FilteredTrafficTab"
                                      Style="{StaticResource RhinoPillToggle}"
                                      Click="FilteredTrafficTab_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="FilteredTrafficTabText" Text="Filtered Traffic" VerticalAlignment="Center" />
                                <Border x:Name="FilteredTrafficTabBadge" Margin="8,0,0,0"
                                        Background="#33FFFFFF" CornerRadius="8" Padding="6,1"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="FilteredTrafficTabCount" Text="0"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" />
                                </Border>
                            </StackPanel>
                        </ToggleButton>

                        <!-- Filtered Traffic sub-row toggles (wired in Phase 3) -->
                        <StackPanel x:Name="FilteredSubToggles" Orientation="Horizontal" Margin="14,0,0,0" Visibility="Collapsed">
                            <TextBlock Text="Source:" FontSize="10"
                                       Foreground="{DynamicResource TextFaint}"
                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ToggleButton x:Name="FilterSourcePacket"
                                          Style="{StaticResource RhinoPillToggleSmall}"
                                          IsChecked="True"
                                          Margin="0,0,4,0"
                                          Click="FilterSource_Click">
                                <TextBlock Text="Packet Filters" />
                            </ToggleButton>
                            <ToggleButton x:Name="FilterSourcePsn"
                                          Style="{StaticResource RhinoPillToggleSmall}"
                                          Margin="0,0,4,0"
                                          Click="FilterSource_Click">
                                <TextBlock Text="PlayStation" />
                            </ToggleButton>
                            <ToggleButton x:Name="FilterSourceXbox"
                                          Style="{StaticResource RhinoPillToggleSmall}"
                                          Click="FilterSource_Click">
                                <TextBlock Text="XBOX" />
                            </ToggleButton>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stats bar: status pill + counters + protocol pills -->
                <Border x:Name="StatsBarBorder" Grid.Row="2" Background="{DynamicResource StatsBarBg}" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <!-- Captured Packets status pill: chart icon + label + live dot -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ChartLine" Width="14" Height="14"
                                                     Foreground="{DynamicResource AccentTeal}"
                                                     VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="Captured Packets" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                            <Ellipse x:Name="StatsLiveDot" Width="6" Height="6" Margin="6,0,0,0"
                                     Fill="{DynamicResource StatusSuccess}" VerticalAlignment="Center"
                                     Visibility="Collapsed" />
                        </StackPanel>

                        <materialDesign:PackIcon Kind="Earth" Foreground="{DynamicResource AccentTeal}" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock x:Name="StatsIpCount" Text="0 IPs" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0" />
                        <materialDesign:PackIcon Kind="FileExportOutline" Foreground="{DynamicResource TextFaint}" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock x:Name="StatsPacketCount" Text="0 packets" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0" />
                        <materialDesign:PackIcon Kind="ArrowUp" Foreground="{DynamicResource TextFaint}" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBlock x:Name="StatsTotalData" Text="0 B" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center" Margin="0,0,20,0" />
                        <TextBlock Text="PROTOCOLS:" Foreground="{DynamicResource TextDim}" FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Border Background="{DynamicResource ProtoTcpBg}" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock x:Name="StatsTcpCount" Text="TCP 0" Foreground="{DynamicResource ProtoTcpText}" FontSize="10" />
                        </Border>
                        <Border Background="{DynamicResource ProtoUdpBg}" CornerRadius="3" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock x:Name="StatsUdpCount" Text="UDP 0" Foreground="{DynamicResource ProtoUdpText}" FontSize="10" />
                        </Border>
                        <Border Background="{DynamicResource ProtoBothBg}" CornerRadius="3" Padding="6,2">
                            <TextBlock x:Name="StatsBothCount" Text="BOTH 0" Foreground="{DynamicResource ProtoBothText}" FontSize="10" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Search bar -->
                <Border x:Name="SearchBarBorder" Grid.Row="3" Background="{DynamicResource SearchBarBg}" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="0"
                                 Background="{DynamicResource SearchBoxBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource SearchBoxBorder}"
                                 BorderThickness="1"
                                 Padding="8,4"
                                 FontSize="12"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 materialDesign:HintAssist.Hint="Search IP, protocol, or traffic type..."
                                 materialDesign:HintAssist.HintOpacity="0.4"
                                 Style="{StaticResource MaterialDesignTextBox}" />
                        <materialDesign:PackIcon Grid.Column="1" Kind="Magnify"
                                                 Foreground="{DynamicResource TextFaint}"
                                                 Width="18" Height="18"
                                                 VerticalAlignment="Center"
                                                 Margin="6,0,4,0" />
                    </Grid>
                </Border>

                <DataGrid
                    x:Name="MainDataGrid"
                    Grid.Row="4"
                    AlternationCount="2"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    AutoGenerateColumns="False"
                    Background="{DynamicResource GridBg}"
                    BeginningEdit="Grid_BeginningEdit"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="True"
                    CanUserResizeRows="False"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{DynamicResource DividerSoft}"
                    IsSynchronizedWithCurrentItem="False"
                    MouseDoubleClick="DataGridView_MouseDoubleClick"
                    ContextMenuOpening="MainDataGrid_ContextMenuOpening"
                    PreviewMouseDown="MainDataGrid_MouseDown"
                    RenderTransformOrigin="0.5,0.5"
                    RowHeight="28"
                    SelectionMode="Single"
                    SelectionUnit="FullRow"
                    VerticalGridLinesBrush="Transparent"
                    CanUserSortColumns="True"
                    HeadersVisibility="Column"
                    ColumnHeaderHeight="32">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="6,0,6,0" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Grid>
                                            <Border x:Name="HeaderBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ContentPresenter VerticalAlignment="Center"
                                                                      RecognizesAccessKey="True"
                                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                    <materialDesign:PackIcon x:Name="SortIconUnsorted"
                                                                             Kind="UnfoldMoreHorizontal"
                                                                             Width="12" Height="12"
                                                                             Margin="4,0,0,0"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="{DynamicResource TextFaint}"
                                                                             Opacity="0.5" />
                                                    <materialDesign:PackIcon x:Name="SortIconAsc"
                                                                             Kind="ChevronUp"
                                                                             Width="12" Height="12"
                                                                             Margin="4,0,0,0"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="{DynamicResource TextPrimary}"
                                                                             Visibility="Collapsed" />
                                                    <materialDesign:PackIcon x:Name="SortIconDesc"
                                                                             Kind="ChevronDown"
                                                                             Width="12" Height="12"
                                                                             Margin="4,0,0,0"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="{DynamicResource TextPrimary}"
                                                                             Visibility="Collapsed" />
                                                </StackPanel>
                                            </Border>
                                            <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left"
                                                   Width="4" Cursor="SizeWE" Background="Transparent">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="Transparent" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                            <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right"
                                                   Width="4" Cursor="SizeWE" Background="Transparent">
                                                <Thumb.Style>
                                                    <Style TargetType="Thumb">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Border Background="Transparent" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Thumb.Style>
                                            </Thumb>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <!-- Hide all sort icons when there's no SortMemberPath (e.g. flag column) -->
                                            <Trigger Property="CanUserSort" Value="False">
                                                <Setter TargetName="SortIconUnsorted" Property="Visibility" Value="Collapsed" />
                                            </Trigger>
                                            <Trigger Property="SortDirection" Value="Ascending">
                                                <Setter TargetName="SortIconUnsorted" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="SortIconAsc" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                            <Trigger Property="SortDirection" Value="Descending">
                                                <Setter TargetName="SortIconUnsorted" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="SortIconDesc" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                            <Setter Property="Padding" Value="6,0,6,0" />
                            <Setter Property="FontSize" Value="12.5" />
                            <Setter Property="BorderThickness" Value="0" />
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </DataGrid.RenderTransform>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="BorderThickness" Value="3,0,0,0" />
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="0">
                                    <Setter Property="BorderBrush" Value="{DynamicResource StatusSuccess}" />
                                </Trigger>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="BorderBrush" Value="{DynamicResource StatusInfo}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IspDimmed}" Value="True">
                                    <Setter Property="Opacity" Value="0.35" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <!-- Flag (filter-icon slot) -->
                        <DataGridTemplateColumn Width="28" MinWidth="28" MaxWidth="28" CanUserSort="False">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <Image Source="{Binding Flag}" Width="20" Height="14" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- IP Address (with padlock prefix icon) -->
                        <DataGridTemplateColumn Width="1.6*" MinWidth="140" SortMemberPath="IpAddress">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="IP Address" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="LockOutline" Width="12" Height="12"
                                                                 Margin="0,0,6,0"
                                                                 Foreground="{DynamicResource TextFaint}"
                                                                 VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding IpAddress}" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- PORTS -->
                        <DataGridTemplateColumn Width="0.7*" MinWidth="60" SortMemberPath="Port">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Ports" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding Port}" TextAlignment="Left" FontFamily="Consolas" FontSize="11" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- COUNTRY (blank when geo failed; mirrors Location/Region/ISP behavior) -->
                        <DataGridTemplateColumn Width="1*" MinWidth="80" SortMemberPath="Country">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Country" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding Country}" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding GeoFailed, Converter={StaticResource InverseBoolToVisConverter}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- LOCATION (city) -->
                        <DataGridTemplateColumn Width="1*" MinWidth="70" SortMemberPath="City">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Location" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding City}" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding GeoFailed, Converter={StaticResource InverseBoolToVisConverter}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- REGION (bound to State — ip-api regionName) -->
                        <DataGridTemplateColumn Width="1*" MinWidth="70" SortMemberPath="State">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Region" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding State}" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextMuted}"
                                               Visibility="{Binding GeoFailed, Converter={StaticResource InverseBoolToVisConverter}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- ISP -->
                        <DataGridTemplateColumn Width="1.5*" MinWidth="100" SortMemberPath="Isp">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="ISP" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding Isp}" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding GeoFailed, Converter={StaticResource InverseBoolToVisConverter}}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Proto -->
                        <DataGridTemplateColumn Width="56" MinWidth="56" SortMemberPath="Protocol">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Proto" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <Border CornerRadius="3" Padding="6,1" HorizontalAlignment="Center"
                                            Background="{Binding Protocol, Converter={StaticResource ProtocolToBgConverter}}">
                                        <TextBlock Text="{Binding Protocol}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{Binding Protocol, Converter={StaticResource ProtocolToFgConverter}}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Packets — number + horizontal % bar -->
                        <DataGridTemplateColumn Width="0.9*" MinWidth="80" SortMemberPath="Packets">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Packets" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Packets}" TextAlignment="Left"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontFamily="Consolas" FontSize="11" />
                                        <Border Grid.Row="1" Height="2" Margin="0,3,8,0"
                                                HorizontalAlignment="Left"
                                                CornerRadius="1"
                                                Background="{DynamicResource StatusInfo}"
                                                Width="{Binding PacketsBarWidth}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Data In (was Up) -->
                        <DataGridTemplateColumn Width="0.8*" MinWidth="68" SortMemberPath="Upload">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Data In" Foreground="{DynamicResource DataInText}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding Upload}" Foreground="{DynamicResource DataInText}" TextAlignment="Left" FontFamily="Consolas" FontSize="11" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Data Out (was Down) -->
                        <DataGridTemplateColumn Width="0.8*" MinWidth="68" SortMemberPath="Download">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Data Out" Foreground="{DynamicResource DataOutText}" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding Download}" Foreground="{DynamicResource DataOutText}" TextAlignment="Left" FontFamily="Consolas" FontSize="11" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Last seen — small clock-icon header label -->
                        <DataGridTemplateColumn Width="56" MinWidth="56" SortMemberPath="LastSeenText">
                            <DataGridTemplateColumn.Header>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ClockOutline" Width="11" Height="11"
                                                             Margin="0,0,3,0" VerticalAlignment="Center" />
                                    <TextBlock Text="Last" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding LastSeenText}" Foreground="{DynamicResource TextMuted}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Packet Type — pill badge -->
                        <DataGridTemplateColumn Width="1*" MinWidth="90" SortMemberPath="PacketType">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Packet Type" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Left"
                                            Background="{DynamicResource PacketTypePillBg}"
                                            BorderBrush="{DynamicResource PacketTypePillBorder}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding PacketType}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- DDoS shield icon (kept) -->
                        <DataGridTemplateColumn Width="28" MinWidth="28" MaxWidth="28" CanUserSort="False">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <materialDesign:PackIcon Kind="{Binding DDoSProtected}" Width="16" Height="16" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Label (kept) -->
                        <DataGridTemplateColumn Width="0.8*" MinWidth="60" SortMemberPath="Label">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="Label" />
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="models:CaptureGrid">
                                    <TextBlock Text="{Binding Label}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource LabelText}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.InputBindings>
                        <KeyBinding Key="C" Modifiers="Ctrl+Shift" Command="{x:Static window:MainWindow.CopyCommand}" />
                        <KeyBinding Key="D" Modifiers="Ctrl" Command="{x:Static window:MainWindow.RemoveAtCommand}" />
                        <KeyBinding Key="D" Modifiers="Ctrl+Shift" Command="{x:Static window:MainWindow.ClearAllCommand}" />
                        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static window:MainWindow.MoveToGamesCommand}" />
                    </DataGrid.InputBindings>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <!-- ── Group 1: row actions ────────────────────────────────── -->
                            <MenuItem Command="{x:Static window:MainWindow.CopyCommand}" InputGestureText="Ctrl+Shift+C">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="ContentCopy" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Copy Row</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Name="AnalyseMenuItem"
                                Command="{x:Static window:MainWindow.AnalyseCommand}"
                                ToolTip="Inspect the selected flow in the packet analyser">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="EyeOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Inspect Flow</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Name="AddToLabelsMenuItem"
                                Command="{x:Static window:MainWindow.LabelCommand}"
                                ToolTip="Save this IP to IP Storage with a custom label">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="TagOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Create IP label</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator />
                            <!-- ── Group 2: tool navigation (pre-fills selected IP) ────── -->
                            <MenuItem
                                Command="{x:Static window:MainWindow.PacketTestCommand}"
                                ToolTip="Open Packet Tester with this IP pre-filled">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Send" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Packet Test</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.PortScanCommand}"
                                ToolTip="Open Nmap Scanner with this IP pre-filled">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Radar" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Port Scan</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.GeoIpLookupCommand}"
                                ToolTip="Open Geo IP Lookup with this IP pre-filled and auto-lookup">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Earth" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Geo IP Lookup</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator />
                            <!-- ── Group 3: hide ISP (dynamic header) ──────────────────── -->
                            <MenuItem
                                Name="HideIspMenuItem"
                                Command="{x:Static window:MainWindow.HideIspCommand}"
                                ToolTip="Hide all current and future packets from this ISP">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="EyeOffOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock x:Name="HideIspHeaderText" Text="Hide ISP" />
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator />
                            <!-- ── Group 4: RhinoSniff-exclusive actions ───────────────── -->
                            <MenuItem
                                Command="{x:Static window:MainWindow.MoveToGamesCommand}" InputGestureText="Ctrl+F"
                                ToolTip="Move selected row(s) to Filtered Traffic">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="GamepadVariantOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Move to Filtered</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.LocateCommand}"
                                ToolTip="View advanced location information about this entry">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="MapMarkerOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Locate (advanced)</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.TcpProbeCommand}"
                                ToolTip="Initiate a TCP connection to the host on the specified TCP destination port">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="SatelliteVariant" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>TCP Probe</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator />
                            <!-- ── Group 5: export ─────────────────────────────────────── -->
                            <MenuItem
                                Command="{x:Static window:MainWindow.ExportCommand}"
                                ToolTip="Export all capture results to a text file">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="FileExportOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Export</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.ExportPcapCommand}"
                                ToolTip="Export raw packet capture to a .pcap file (Wireshark compatible)">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="FileDownloadOutline" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>Export PCAP</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.WhoisAllCommand}"
                                ToolTip="Export WHOIS/geo data for all captured connections">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Database" Foreground="{DynamicResource AccentTeal}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock>WHOIS All</TextBlock>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator />
                            <!-- ── Group 6: destructive (red) ──────────────────────────── -->
                            <MenuItem
                                Command="{x:Static window:MainWindow.RemoveAtCommand}" InputGestureText="Ctrl+D"
                                ToolTip="Remove selected entry"
                                Foreground="{DynamicResource StatusDanger}">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="TrashCanOutline" Foreground="{DynamicResource StatusDanger}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock Text="Clear Row" Foreground="{DynamicResource StatusDanger}" />
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem
                                Command="{x:Static window:MainWindow.ClearAllCommand}" InputGestureText="Ctrl+Shift+D"
                                ToolTip="Clear all entries"
                                Foreground="{DynamicResource StatusDanger}">
                                <MenuItem.Icon>
                                    <materialDesign:PackIcon Kind="Close" Foreground="{DynamicResource StatusDanger}" />
                                </MenuItem.Icon>
                                <MenuItem.Header>
                                    <TextBlock Text="Clear All" Foreground="{DynamicResource StatusDanger}" />
                                </MenuItem.Header>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <!-- Empty state: shown on Filtered tab when gamesDataSource is empty -->
                <Border x:Name="FilteredEmptyOverlay" Grid.Row="4" Visibility="Collapsed"
                        Background="{DynamicResource GridBg}" IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="EarthOff" Width="48" Height="48"
                                                 Foreground="{DynamicResource TextFaint}"
                                                 HorizontalAlignment="Center" />
                        <TextBlock Text="No Traffic Data" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" Margin="0,12,0,4" />
                        <TextBlock Text="Move rows from All Traffic, or enable a packet filter."
                                   FontSize="11" Foreground="{DynamicResource TextFaint}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Status bar -->
                <Border x:Name="BottomStatusBorder" Grid.Row="5" Background="{DynamicResource BottomStatusBg}" BorderBrush="{DynamicResource BottomStatusBorder}" BorderThickness="0,1,0,0"
                        Padding="12,4">
                    <Grid>
                        <TextBlock x:Name="StatusBarText"
                                   Text="Ready"
                                   Foreground="{DynamicResource TextFaint}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left" />
                        <TextBlock x:Name="StatusBarRight"
                                   Foreground="{DynamicResource TextFaint}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right">
                            <Run x:Name="StatusTabName" Text="" />
                            <Run Text="    " />
                            <Run x:Name="StatusCapturedPackets" Text="Captured Packets: 0" />
                        </TextBlock>
                    </Grid>
                </Border>

                    </Grid>
                    <!-- ═══ PHASE 3: Filter content pages (hidden by default) ═══ -->
                    <ContentControl x:Name="PacketFiltersHost" Visibility="Collapsed" />
                    <ContentControl x:Name="IspFiltersHost" Visibility="Collapsed" />
                    <ContentControl x:Name="DeviceFiltersHost" Visibility="Collapsed" />
                    <!-- ═══ PHASE 4: ARP + Tools content pages ═══ -->
                    <ContentControl x:Name="ArpHost" Visibility="Collapsed" />
                    <ContentControl x:Name="GeoIpHost" Visibility="Collapsed" />
                    <ContentControl x:Name="NmapHost" Visibility="Collapsed" />
                    <ContentControl x:Name="PingHost" Visibility="Collapsed" />
                    <ContentControl x:Name="PacketTesterHost" Visibility="Collapsed" />

                    <!-- Phase 8: Traffic Control host -->
                    <ContentControl x:Name="TrafficControlHost" Visibility="Collapsed" />

                    <!-- Phase 5 hosts -->
                    <ContentControl x:Name="IpStorageHost" Visibility="Collapsed" />
                    <ContentControl x:Name="HotspotHost" Visibility="Collapsed" />
                    <!-- Phase 6: content-area Settings host (sub-sidebar inside) -->
                    <ContentControl x:Name="SettingsHost" Visibility="Collapsed" />
                </Grid>
                <Grid
                    x:Name="Canvas"
                    Grid.Row="1" Grid.Column="1"
                    Height="0"
                    Visibility="Collapsed"
                    RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Grid.RenderTransform>
                </Grid>
                <Canvas
                    x:Name="Grid"
                    Grid.Row="1" Grid.Column="1"
                    Width="104"
                    Height="29"
                    Visibility="Collapsed"
                    RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Canvas.RenderTransform>
                    <Button
                        x:Name="MaxBottom"
                        Width="{Binding ActualWidth, ElementName=Grid}"
                        Height="{Binding ActualHeight, ElementName=Grid}"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{x:Static window:MainWindow.TogglePanelCommand}"
                        Cursor="Arrow"
                        Foreground="{DynamicResource TextPrimary}"
                        RenderTransformOrigin="0.5,0.5"
                        ToolTip="Show / hide the control panel">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Button.RenderTransform>
                        <materialDesign:PackIcon
                            x:Name="PackIcon"
                            Kind="ArrowUp"
                            RenderTransformOrigin="0.5,0.5">
                            <materialDesign:PackIcon.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <SkewTransform />
                                    <RotateTransform Angle="180.254" />
                                    <TranslateTransform />
                                </TransformGroup>
                            </materialDesign:PackIcon.RenderTransform>
                        </materialDesign:PackIcon>
                    </Button>
                </Canvas>
                <Grid
                    x:Name="NotificationGrid"
                    Grid.Row="1" Grid.Column="1"
                    Width="435"
                    Height="87"
                    MaxWidth="435"
                    MaxHeight="87"
                    Margin="655,10,10,471"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{DynamicResource NotificationBg}"
                    Opacity="100"
                    RenderTransformOrigin="0.5,0.5"
                    Visibility="Hidden">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Grid.Effect>
                        <DropShadowEffect
                            BlurRadius="10"
                            Direction="0"
                            Opacity="1"
                            RenderingBias="Quality"
                            ShadowDepth="0" />
                    </Grid.Effect>
                    <Button
                        Width="45"
                        Height="87"
                        Margin="390,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{x:Static window:MainWindow.HideNotification}"
                        Cursor="Arrow"
                        Foreground="{DynamicResource TextPrimary}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon Kind="WindowClose" />
                    </Button>
                    <Label
                        x:Name="NotificationTitle"
                        Margin="77,11,50,54"
                        Content="Notice"
                        Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock
                        x:Name="NotificationDescription"
                        Margin="81,33,50,9"
                        Foreground="{DynamicResource TextDim}"
                        Text="Description"
                        TextWrapping="WrapWithOverflow" />
                    <materialDesign:PackIcon
                        x:Name="NotificationIcon"
                        Width="48"
                        Height="52"
                        Margin="15,0,0,0"
                        VerticalAlignment="Center"
                        Kind="InfoOutline" />
                </Grid>
                <Grid
                    x:Name="SideViewCanvas"
                    Grid.Row="0" Grid.RowSpan="2"
                    Grid.Column="2"
                    MaxWidth="800"
                    Margin="20,0,-315,0"
                    Background="{DynamicResource SideViewBg}"
                    RenderTransformOrigin="0.5,0.5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64" />
                        <RowDefinition Height="568*" />
                    </Grid.RowDefinitions>
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Rectangle
                        Grid.Row="0"
                        Width="296"
                        Height="64"
                        Fill="{DynamicResource SideViewHeaderBg}"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <Rectangle.Effect>
                            <DropShadowEffect
                                BlurRadius="25"
                                Direction="315"
                                ShadowDepth="5" />
                        </Rectangle.Effect>
                    </Rectangle>
                    <TextBlock
                        x:Name="SideViewTitle"
                        Grid.Row="0"
                        Margin="20,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource RhinoSniffTitle}"
                        Text="Title"
                        TextAlignment="Center"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button
                        x:Name="CloseSideView"
                        Grid.Row="0"
                        Width="64"
                        Height="64"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Background="{x:Null}"
                        BorderBrush="{x:Null}"
                        Command="{x:Static window:MainWindow.HideSideView}"
                        Cursor="Arrow"
                        Foreground="{DynamicResource TextPrimary}"
                        ToolTip="Hide this view"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                        <materialDesign:PackIcon
                            x:Name="PackIcon1"
                            Width="17"
                            Height="17"
                            Kind="WindowClose"
                            RenderTransformOrigin="0.5,0.5"
                            ToolTip="Close RhinoSniff">
                            <materialDesign:PackIcon.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform />
                                    <SkewTransform />
                                    <RotateTransform />
                                    <TranslateTransform />
                                </TransformGroup>
                            </materialDesign:PackIcon.RenderTransform>
                        </materialDesign:PackIcon>
                    </Button>
                    <Frame
                        x:Name="SideViewFrame"
                        Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        NavigationUIVisibility="Hidden"
                        RenderTransformOrigin="0.5,0.5">
                        <Frame.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform />
                                <TranslateTransform />
                            </TransformGroup>
                        </Frame.RenderTransform>
                    </Frame>
                </Grid>
            </Grid>
        </materialDesign:DialogHost>
    </Border>
</Window>